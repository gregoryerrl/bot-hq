# bot-hq (Rust + Slint rebuild) — environment configuration
# Copy to .env (gitignored) and edit. Variables here are read at startup.

# =============================================================================
# Data directory
# =============================================================================
# Override the default CL + DB location. Defaults to ~/.bot-hq/.
# During development, point at ~/.bot-hq-dev/ to avoid colliding with the
# still-running current bot-hq (which owns ~/.bot-hq/).
BOT_HQ_DATA_DIR=~/.bot-hq-dev/

# =============================================================================
# Live tests
# =============================================================================
# Phase 2.5 and Phase 3.5 smoke tests spawn a real claude-code subprocess.
# Set this to "1" before running `cargo test` to include them.
# RUN_LIVE_TESTS=1

# =============================================================================
# Agent credentials
# =============================================================================
# Per-agent provider/model/auth_token live in the agent_configs sqlite table,
# edited from the Settings tab. The Anthropic default below is only used as a
# fallback if a row is missing — and the Settings UI is the canonical surface.
# ANTHROPIC_API_KEY=sk-ant-api03-…

# =============================================================================
# Logging
# =============================================================================
# tracing-subscriber EnvFilter. Defaults to "info,bot_hq=debug".
# RUST_LOG=info,bot_hq=debug
