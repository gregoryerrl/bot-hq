// bot-hq UI — Material 3 dark theme translated from the Stitch design exports
// at ~/Downloads/stitch_bot_hq_desktop_rebuild/.
//
// Tokens (palette, type scale, spacing, radii) come from the Tailwind config
// block embedded in the Stitch HTML. Layout primitives map Tailwind
// flex/grid classes to Slint's HorizontalLayout / VerticalLayout.
//
// Icons: Unicode glyphs that approximate Material Symbols Outlined. Swap to
// the Material Symbols font in a follow-up pass for pixel fidelity.

import { LineEdit, ScrollView, TextEdit } from "std-widgets.slint";

// Bundled font — Slint compiler embeds + registers at build time so we don't
// depend on the user having JetBrains Mono installed system-wide.
import "../fonts/JetBrainsMono-VariableFont_wght.ttf";

// ---- Shared structs surfaced to Rust via include_modules!() ----------------

export struct SessionTile {
    id: string,
    title: string,
    phase: string,
    last-activity: string,
    awaiting: bool,
    // How many pending user-input rows live in `session_questions` for this
    // session — sum of pending choices + halts + open-asks. Drives the
    // dashboard card's `[Need User Input · N]` chip. The full content lives
    // inside the session's questions tray, not on the card.
    pending-input-count: int,
    quickview: string,
}

/// One pending user-facing item rendered in the per-session questions tray.
/// `kind` ∈ {"choice", "open_ask", "halt"}. `options` is empty for non-choice.
export struct PendingQuestion {
    choice-id: string,
    kind: string,
    agent: string,
    prompt: string,
    options: [string],
    asked-at: string,
}

export struct ChatMsg {
    author: string,
    kind: string,
    content: string,
    created-at: string,
}

export struct AgentConfigRow {
    agent-name: string,
    provider: string,
    model-name: string,
    base-url: string,
    auth-token: string,
}

export struct NewSessionProject {
    name: string,
    // Working repo path from the CL `projects` table. Used as
    // `working_repo_path` when the session is created.
    path: string,
}

export struct CLFileEntry {
    relative-path: string,
    display-name: string,
    is-dir: bool,
    depth: int,
    // True when this entry is a directory currently expanded in the tree.
    // Chevron renders ▾ when true, ▸ when false. Files always false.
    expanded: bool,
    // True when the walker emitted this row as a placeholder for the in-flight
    // inline create (new-file or new-folder under `relative-path`'s parent).
    // The row renders a TextInput instead of static text. `relative-path`
    // for ghost rows is the synthetic "<parent>/__ghost__" sentinel.
    is-ghost: bool,
    // True when this directory's absolute path matches a `projects.cl_path`
    // (or the default `<data_dir>/projects/<name>/` convention). Drives the
    // registered-project visual differentiation in CLTreeRow.
    is-registered-project: bool,
    // Folder description (from `cl_folders`). Empty for files and for folders
    // with no description on record. Populated so the row can surface a hint
    // without a separate DB round-trip.
    description: string,
}

// ---- Design tokens ---------------------------------------------------------

export global Theme {
    // Canvas + 5-tier surface elevation.
    out property <color> bg-canvas:        #0b1326;
    out property <color> surface-lowest:   #060e20;
    out property <color> surface-low:      #131b2e;
    out property <color> surface:          #171f33;
    out property <color> surface-high:     #222a3d;
    out property <color> surface-highest:  #2d3449;
    out property <color> surface-variant:  #2d3449;

    // Primary (peach/orange).
    out property <color> primary:           #ffb68b;
    out property <color> primary-container: #ff7a00;
    out property <color> on-primary:        #522300;
    out property <color> primary-fixed:     #ffdbc8;

    // Secondary (purple).
    out property <color> secondary:           #ddb7ff;
    out property <color> secondary-container: #6f00be;
    out property <color> on-secondary:        #490080;

    // Tertiary (blue).
    out property <color> tertiary:           #adc6ff;
    out property <color> tertiary-container: #6d9fff;
    out property <color> on-tertiary:        #002e6a;

    // Error.
    out property <color> error:           #ffb4ab;
    out property <color> error-container: #93000a;
    out property <color> on-error:        #690005;

    // Text + outlines.
    out property <color> on-surface:         #dae2fd;
    out property <color> on-surface-variant: #e0c0af;
    out property <color> outline:            #a78b7c;
    out property <color> outline-variant:    #584235;

    // Status.
    out property <color> status-online: #10b981;

    // Phase mapping.
    out property <color> phase-i: #adc6ff;
    out property <color> phase-p: #ddb7ff;
    out property <color> phase-a: #ffb68b;
    out property <color> phase-v: #ffb68b;

    // Author keys.
    out property <color> author-user:  #adc6ff;
    out property <color> author-brian: #ffb68b;
    out property <color> author-rain:  #ddb7ff;
    out property <color> author-emma:  #ffb68b;

    // Typography (system fallback if not installed).
    out property <string> font-display: "Hanken Grotesk";
    out property <string> font-body:    "Inter";
    out property <string> font-mono:    "JetBrains Mono";

    // Type scale.
    out property <length> font-label:    11px;
    out property <length> font-code:     12px;
    out property <length> font-body-md:  14px;
    out property <length> font-head-md:  18px;
    out property <length> font-head-lg:  24px;

    // Letter-spacing.
    out property <length> ls-label:     0.55px;
    out property <length> ls-headline: -0.48px;

    // Weights.
    out property <int> w-regular: 400;
    out property <int> w-medium:  500;
    out property <int> w-semi:    600;
    out property <int> w-bold:    700;

    // Spacing.
    out property <length> s-1: 4px;
    out property <length> s-2: 8px;
    out property <length> s-3: 12px;
    out property <length> s-4: 16px;
    out property <length> s-5: 20px;
    out property <length> s-6: 24px;

    // Radii.
    out property <length> radius-default: 2px;
    out property <length> radius-lg:      4px;
    out property <length> radius-xl:      8px;

    // Layout dims.
    out property <length> topbar-h: 48px;
    out property <length> footer-h: 32px;
}

// ---- Global state ----------------------------------------------------------

export global AppState {
    in-out property <int> current-tab;
    in     property <bool> emma-open;
    in     property <string> status-text;

    in     property <[SessionTile]> sessions;
    in-out property <string> active-session-id;

    in     property <[ChatMsg]> session-msgs;
    // Counter Rust increments after each set_session_msgs / set_emma_msgs.
    // SessionView and EmmaPane watch their respective tick via a local property
    // + `changed` handler, then scroll their ScrollView to the bottom. This
    // decouples auto-scroll from layout-time `changed viewport-height`, which
    // was unreliable on model swaps and recursed on EmmaPane's layout.
    in     property <int> session-scroll-tick;
    in     property <int> emma-scroll-tick;
    in     property <string> active-phase;
    in     property <string> active-title;
    in     property <bool>   active-awaiting;
    // All currently-pending user-input items for the active session, sourced
    // from the durable `session_questions` table. The in-chat questions tray
    // reads this; the dashboard card reads only the count.
    in     property <[PendingQuestion]> active-questions;
    // User-controlled toggle for the tray. Default closed (so the chat is
    // unobstructed); clicking the header chip opens it.
    in-out property <bool>   questions-tray-open;
    // Set true by view_model when at least one row in the tray has a
    // user-supplied answer. Drives the "Send all" button enable state.
    in     property <bool>   submit-ready;
    // Called every time the user picks a choice option or types into a
    // halt/open-ask input. `value` is the picked option string (choice)
    // or the typed text (open-ask/halt). view_model maintains the batch
    // accumulator keyed by choice_id.
    callback set-answer(string, string);
    // Fires the batched submission: drains the accumulator, resolves each
    // pending choice, marks halt rows answered, broadcasts a combined
    // user message so the agent reads everything as one turn.
    callback submit-questions-batch();
    // Frozen-at-spawn model names for this session's two agents. Header strip
    // reads these so the user sees what's actually talking, not the (mutable)
    // current agent_configs.model_name. Empty for pre-migration session rows.
    in     property <string> active-brian-model;
    in     property <string> active-rain-model;

    in     property <[ChatMsg]> emma-msgs;
    // Emma has no dashboard tile + isn't an "active session" in the SessionView
    // sense, so signaling events for session_id="emma" need a dedicated render
    // surface in EmmaPane. Mirrors the active-pending-* / active-awaiting set.
    in     property <bool>   emma-awaiting;
    in     property <bool>   emma-pending-choice;
    in     property <string> emma-pending-question;
    in     property <[string]> emma-pending-options;
    in     property <string> emma-pending-choice-id;

    in     property <[CLFileEntry]> cl-tree;
    in     property <string> cl-current-path;
    in-out property <string> cl-current-body;
    in-out property <bool>   cl-dirty;
    // Index metadata for the currently open file. Edits set cl-metadata-dirty;
    // saving (Save Changes) commits both body and metadata in one flush.
    in-out property <string> cl-current-description;
    in-out property <string> cl-current-tags;
    in-out property <bool>   cl-metadata-dirty;
    // Folder-view state. When cl-current-folder != "" the right pane swaps
    // from the file editor to CLFolderView; both views are mutually exclusive
    // — opening a file clears cl-current-folder, opening a folder clears
    // cl-current-path. Used to describe folders + (optionally) register them
    // as first-class projects. `cl-current-folder-project-name` is the
    // registered project's name when is-project=true (lets Unregister find
    // the right row even if the user later renamed the folder on disk).
    in     property <string> cl-current-folder;
    in-out property <string> cl-current-folder-description;
    in     property <bool>   cl-current-folder-is-project;
    in     property <string> cl-current-folder-project-name;
    in     property <string> cl-current-folder-working-repo;
    in-out property <bool>   cl-current-folder-dirty;
    // Register-project modal state. Defaults populated by view-model when the
    // user clicks "Register as Project" — cl_path defaults to the folder's
    // absolute path; working_repo_path also defaults to it but is optional.
    in-out property <bool>   cl-register-dialog-open;
    in-out property <string> cl-register-name;
    in-out property <string> cl-register-cl-path;
    in-out property <string> cl-register-working-repo;
    // New-file dialog state.
    in-out property <bool>   cl-new-file-dialog-open;
    in-out property <string> cl-new-file-name;
    in-out property <string> cl-new-file-description;
    // New-session dialog state. Populated by view_model on dashboard refresh.
    // Each entry: { name, path }. Projects without a working_repo_path are
    // filtered out by view_model — the dialog only shows pickable projects.
    in-out property <bool>   new-session-dialog-open;
    in-out property <string> new-session-title;
    in-out property <string> new-session-project-name;
    in-out property <string> new-session-project-path;
    in     property <[NewSessionProject]> new-session-projects;
    // Active session's permission grants (commit / push). View-model refreshes
    // these on signaling tick. Chip click → toggle via set-session-permission.
    in     property <bool> active-commit-granted;
    in     property <bool> active-push-granted;
    // (action, granted) — action is "commit" or "push", granted is the
    // NEW desired state. View-model calls bridge.grant/revoke accordingly.
    callback set-session-permission(string, bool);
    // Delete confirmation state — empty when no dialog open; relative path when open.
    in-out property <string> cl-delete-confirm-path;

    callback cl-create-file(string, string);  // (relative_path, description)
    callback cl-delete-file(string);          // (relative_path)
    callback cl-rescan();
    callback cl-autodescribe();               // generates description via Emma for current file
    // Folder-view callbacks. View-model loads description + project metadata
    // when cl-open-folder fires; save/register/unregister/autodescribe mirror
    // the file-view pattern. All take the folder's tree-relative path
    // (mirrors cl-current-path); empty string is the bot-hq root.
    callback cl-open-folder(string);
    callback cl-save-folder-description();
    callback cl-register-project-open();
    callback cl-register-project-submit();
    callback cl-unregister-project();
    callback cl-autodescribe-folder();

    // VS Code-style tree state. Expanded = folder paths the user has
    // explicitly expanded this session. Folders default to collapsed at
    // startup; opening one adds it to this set and persists in-memory
    // across tab switches but resets at restart. Editing = the single
    // row currently being typed into (inline rename or new-file/folder).
    in     property <[string]> cl-tree-expanded;
    in     property <string>   cl-tree-editing-path;
    in-out property <string>   cl-tree-editing-name;
    in     property <string>   cl-tree-editing-mode;   // "" | "new-file" | "new-folder" | "rename"
    // CL sidebar width. Drag-resizable via the divider; persists across
    // tab switches but resets at app restart.
    in-out property <length>   cl-sidebar-width: 220px;
    callback cl-tree-toggle-collapse(string);            // (folder_path)
    callback cl-tree-begin-create-file(string);          // (parent_dir)  "" = project root pick
    callback cl-tree-begin-create-folder(string);        // (parent_dir)
    callback cl-tree-begin-rename(string);               // (path)
    callback cl-tree-commit-edit();                      // commits whatever editing-mode says
    callback cl-tree-cancel-edit();                      // clears editing state
    callback cl-tree-delete-path(string);                // (path) — file or folder, with confirm

    in     property <[AgentConfigRow]> agent-configs;

    // Transient bottom-center notification (e.g., "Changes will apply to new
    // sessions" after agent config save). Auto-hidden by a 3s Timer in AppWindow.
    in     property <string> toast-text;
    in-out property <bool>   toast-visible;

    // Emma restart confirmation modal. Brian/Rain swaps apply on next session,
    // so they don't need a restart path — but Emma is a singleton and would
    // otherwise need a bot-hq restart to switch model.
    in-out property <bool>   emma-restart-confirm-visible;
    callback restart-emma();

    // External MCP — populated at startup by view_model. Empty when the
    // external server failed to bind (port in use / disabled via env var).
    in     property <string> external-mcp-url;
    in     property <string> external-mcp-token;
    in-out property <bool>   external-mcp-token-revealed;

    callback open-session(string);
    callback back-to-dashboard();
    callback advance-phase(string);
    callback broadcast(string);
    callback emma-send(string);
    callback choice-clicked(string, string);
    callback create-session(string, string);
    callback save-agent-config(AgentConfigRow);
    callback cl-open-file(string);
    callback cl-save-current();
    callback cl-refresh();
    callback toggle-emma();
}

// ---- Reusable primitives ---------------------------------------------------

// Lucide icon codepoint registry. Use `Icons.<name>` as the glyph value
// for the Icon component (the component force-loads the lucide font).
// Names align with the source lucide icon (commented). Extend as we
// adopt more icons.
export global Icons {
    out property <string> plus:          "\u{E13D}";   // lucide:plus
    out property <string> folder-plus:   "\u{E0D9}";   // lucide:folder-plus
    out property <string> x:             "\u{E1B2}";   // lucide:x
    out property <string> trash:         "\u{E18E}";   // lucide:trash-2
    out property <string> edit:          "\u{E1F9}";   // lucide:pencil
    out property <string> check:         "\u{E06C}";   // lucide:check
    out property <string> arrow-left:    "\u{E048}";   // lucide:arrow-left
    out property <string> chevron-right: "\u{E06F}";   // lucide:chevron-right
    out property <string> chevron-down:  "\u{E06D}";   // lucide:chevron-down
    out property <string> refresh:       "\u{E145}";   // lucide:refresh-cw
    out property <string> search:        "\u{E151}";   // lucide:search
    out property <string> file:          "\u{E0C0}";   // lucide:file
    out property <string> folder:        "\u{E0D7}";   // lucide:folder
    out property <string> menu:          "\u{E115}";   // lucide:menu
    out property <string> list:          "\u{E106}";   // lucide:list
    out property <string> play:          "\u{E13C}";   // lucide:play
    out property <string> hash:          "\u{E0EF}";   // lucide:hash
    out property <string> warning:       "\u{E193}";   // lucide:triangle-alert
    out property <string> info:          "\u{E0F9}";   // lucide:info
    out property <string> dot:           "\u{E076}";   // lucide:circle
    out property <string> sparkles:      "\u{E412}";   // lucide:sparkles
    out property <string> settings:      "\u{E154}";   // lucide:settings
    out property <string> wand:          "\u{E357}";   // lucide:wand-2
    out property <string> target:        "\u{E180}";   // lucide:target
    out property <string> lightbulb:     "\u{E1C2}";   // lucide:lightbulb
}

// Lucide icon. Renders any string with the embedded `lucide` font; pair
// with `Icons.<name>` for a stable codepoint reference.
component Icon inherits Text {
    in property <string> glyph;
    in property <length> size: 16px;
    in property <color> tint: Theme.on-surface-variant;
    text: glyph;
    font-family: "lucide";
    font-size: size;
    color: tint;
    vertical-alignment: center;
    horizontal-alignment: center;
}

// Primary CTA — orange fill, dark text.
component PrimaryButton inherits Rectangle {
    in property <string> label;
    in property <string> icon: "";
    in property <length> btn-height: 30px;
    callback clicked();
    height: btn-height;
    horizontal-stretch: 0;
    border-radius: Theme.radius-lg;
    background: ta.has-hover ? Theme.primary-container : Theme.primary;
    animate background { duration: 80ms; }
    HorizontalLayout {
        padding-left: Theme.s-3;
        padding-right: Theme.s-3;
        spacing: Theme.s-2;
        alignment: center;
        if root.icon != "":
            Icon { glyph: root.icon; size: 14px; tint: Theme.on-primary; }
        Text {
            text: root.label;
            color: Theme.on-primary;
            font-family: Theme.font-mono;
            font-size: Theme.font-code;
            font-weight: Theme.w-bold;
            vertical-alignment: center;
        }
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

// Ghost (bordered) button — surface fill, on-surface text.
component GhostButton inherits Rectangle {
    in property <string> label;
    in property <string> icon: "";
    in property <length> btn-height: 30px;
    callback clicked();
    height: btn-height;
    horizontal-stretch: 0;
    border-radius: Theme.radius-lg;
    border-width: 1px;
    border-color: Theme.outline-variant;
    background: ta.has-hover ? Theme.surface-high : Theme.surface;
    animate background { duration: 80ms; }
    HorizontalLayout {
        padding-left: Theme.s-3;
        padding-right: Theme.s-3;
        spacing: Theme.s-2;
        alignment: center;
        if root.icon != "":
            Icon { glyph: root.icon; size: 14px; tint: Theme.on-surface-variant; }
        Text {
            text: root.label;
            color: Theme.on-surface;
            font-family: Theme.font-mono;
            font-size: Theme.font-code;
            vertical-alignment: center;
        }
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

// Small icon-only button (topbar trailing actions).
component IconButton inherits Rectangle {
    in property <string> glyph;
    in property <length> size: 18px;
    in property <color> tint: Theme.on-surface-variant;
    callback clicked();
    width: 28px;
    height: 28px;
    horizontal-stretch: 0;
    border-radius: Theme.radius-lg;
    background: ta.has-hover ? Theme.surface-high : transparent;
    animate background { duration: 80ms; }
    Icon { glyph: root.glyph; size: root.size; tint: root.tint; }
    ta := TouchArea { clicked => { root.clicked(); } }
}

// Label chip — tinted bg + border + label-caps text.
component LabelChip inherits Rectangle {
    in property <string> label;
    in property <color> tint;
    in property <bool> dot: false;
    border-radius: Theme.radius-default;
    border-width: 1px;
    border-color: root.tint.with-alpha(0.3);
    background: root.tint.with-alpha(0.15);
    height: 22px;
    horizontal-stretch: 0;
    HorizontalLayout {
        padding-left: Theme.s-2;
        padding-right: Theme.s-2;
        spacing: Theme.s-2;
        alignment: center;
        if root.dot: Rectangle {
            width: 6px; height: 6px;
            border-radius: 3px;
            background: root.tint;
            vertical-stretch: 0;
        }
        Text {
            text: root.label;
            color: root.tint;
            font-family: Theme.font-mono;
            font-size: Theme.font-label;
            letter-spacing: Theme.ls-label;
            font-weight: Theme.w-bold;
            vertical-alignment: center;
        }
    }
}

// Phase chip — colored by IPAV letter.
component PhaseChip inherits LabelChip {
    in property <string> phase;
    label:
        phase == "I" ? "INVESTIGATE" :
        phase == "P" ? "PLAN" :
        phase == "A" ? "APPLY" :
        phase == "V" ? "VERIFY" : "—";
    tint:
        phase == "I" ? Theme.phase-i :
        phase == "P" ? Theme.phase-p :
        phase == "A" ? Theme.phase-a :
        phase == "V" ? Theme.phase-v :
        Theme.on-surface-variant;
}

// Bordered text input — used everywhere except std LineEdit fallbacks.
component CustomInput inherits Rectangle {
    in property <string> placeholder;
    in-out property <string> text;
    in property <bool> password: false;
    in property <length> input-height: 32px;
    callback accepted(string);
    callback edited();
    height: input-height;
    border-radius: Theme.radius-lg;
    border-width: 1px;
    border-color: input.has-focus ? Theme.primary : Theme.outline-variant;
    background: Theme.surface-lowest;
    animate border-color { duration: 100ms; }
    HorizontalLayout {
        padding-left: Theme.s-3;
        padding-right: Theme.s-3;
        alignment: stretch;
        input := TextInput {
            text <=> root.text;
            color: Theme.on-surface;
            font-family: Theme.font-mono;
            font-size: Theme.font-code;
            vertical-alignment: center;
            single-line: true;
            input-type: root.password ? InputType.password : InputType.text;
            selection-background-color: Theme.primary.with-alpha(0.4);
            selection-foreground-color: Theme.on-surface;
            accepted => { root.accepted(self.text); }
            edited => { root.edited(); }
        }
    }
    // Placeholder overlay (shown when empty + not focused).
    if root.text == "" && !input.has-focus:
        HorizontalLayout {
            padding-left: Theme.s-3;
            padding-right: Theme.s-3;
            alignment: start;
            Text {
                text: root.placeholder;
                color: Theme.on-surface-variant.with-alpha(0.5);
                font-family: Theme.font-mono;
                font-size: Theme.font-code;
                vertical-alignment: center;
            }
        }
}

// ---- Topbar ----------------------------------------------------------------

component TopbarTab inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    callback clicked();
    height: Theme.topbar-h;
    horizontal-stretch: 0;
    background: transparent;

    HorizontalLayout {
        padding-left: Theme.s-2;
        padding-right: Theme.s-2;
        alignment: center;
        Text {
            text: root.label;
            color: root.selected ? Theme.primary
                 : ta.has-hover ? Theme.on-surface
                 : Theme.on-surface-variant;
            font-family: Theme.font-display;
            font-size: Theme.font-head-md;
            font-weight: Theme.w-semi;
            vertical-alignment: center;
        }
    }
    // Underline indicator — orange when selected.
    Rectangle {
        x: Theme.s-2;
        y: parent.height - 3px;
        width: parent.width - Theme.s-2 * 2;
        height: 2px;
        background: root.selected ? Theme.primary : transparent;
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

component EmmaChip inherits Rectangle {
    in property <bool> active;
    callback clicked();
    height: 28px;
    horizontal-stretch: 0;
    border-radius: Theme.radius-lg;
    border-width: 1px;
    border-color: root.active ? Theme.primary : Theme.outline-variant;
    background: root.active
        ? Theme.primary-container.with-alpha(0.25)
        : ta.has-hover ? Theme.surface-high : Theme.surface;
    animate background, border-color { duration: 80ms; }
    HorizontalLayout {
        padding-left: Theme.s-3;
        padding-right: Theme.s-3;
        spacing: Theme.s-2;
        alignment: center;
        Icon { glyph: Icons.target; size: 12px; tint: Theme.primary; }
        Text {
            text: "Emma";
            color: Theme.primary;
            font-family: Theme.font-mono;
            font-size: Theme.font-code;
            font-weight: Theme.w-bold;
            vertical-alignment: center;
        }
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

component Topbar inherits Rectangle {
    background: Theme.bg-canvas;
    height: Theme.topbar-h;
    // 1px bottom divider.
    Rectangle {
        x: 0; y: parent.height - 1px;
        width: parent.width; height: 1px;
        background: Theme.outline-variant;
    }
    HorizontalLayout {
        padding-left: Theme.s-4;
        padding-right: Theme.s-4;
        spacing: Theme.s-5;
        alignment: stretch;

        // Wordmark + nav.
        HorizontalLayout {
            spacing: Theme.s-5;
            alignment: start;
            VerticalLayout {
                alignment: center;
                Text {
                    text: "bot-hq";
                    color: Theme.primary;
                    font-family: Theme.font-display;
                    font-size: Theme.font-head-lg;
                    font-weight: Theme.w-bold;
                    letter-spacing: Theme.ls-headline;
                    vertical-alignment: center;
                }
            }
            TopbarTab {
                label: "Dashboard";
                selected: AppState.current-tab == 0;
                clicked => { AppState.current-tab = 0; AppState.active-session-id = ""; }
            }
            TopbarTab {
                label: "Context Library";
                selected: AppState.current-tab == 1;
                clicked => { AppState.current-tab = 1; }
            }
            TopbarTab {
                label: "Settings";
                selected: AppState.current-tab == 2;
                clicked => { AppState.current-tab = 2; }
            }
        }

        Rectangle { horizontal-stretch: 1; }

        // Search + actions + Emma.
        HorizontalLayout {
            spacing: Theme.s-3;
            alignment: end;
            VerticalLayout {
                alignment: center;
                Rectangle {
                    width: 240px;
                    height: 30px;
                    border-radius: Theme.radius-lg;
                    border-width: 1px;
                    border-color: search.has-focus ? Theme.primary : Theme.outline-variant;
                    background: Theme.surface;
                    animate border-color { duration: 100ms; }
                    HorizontalLayout {
                        padding-left: Theme.s-2;
                        padding-right: Theme.s-2;
                        spacing: Theme.s-2;
                        alignment: stretch;
                        Icon { glyph: Icons.search; size: 16px; tint: Theme.on-surface-variant; }
                        search := TextInput {
                            color: Theme.on-surface;
                            font-family: Theme.font-mono;
                            font-size: Theme.font-code;
                            vertical-alignment: center;
                            single-line: true;
                            horizontal-stretch: 1;
                            selection-background-color: Theme.primary.with-alpha(0.4);
                            selection-foreground-color: Theme.on-surface;
                        }
                    }
                    if search.text == "" && !search.has-focus:
                        HorizontalLayout {
                            padding-left: 32px;
                            padding-right: Theme.s-2;
                            alignment: start;
                            Text {
                                text: "Search sessions...";
                                color: Theme.on-surface-variant.with-alpha(0.6);
                                font-family: Theme.font-mono;
                                font-size: Theme.font-code;
                                vertical-alignment: center;
                            }
                        }
                }
            }
            VerticalLayout {
                alignment: center;
                EmmaChip {
                    active: AppState.emma-open;
                    clicked => { AppState.toggle-emma(); }
                }
            }
        }
    }
}

