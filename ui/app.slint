}

component ChoiceButton inherits Rectangle {
    in property <string> label;
    callback clicked();
    height: 28px;
    horizontal-stretch: 1;
    border-radius: Theme.radius-lg;
    border-width: 1px;
    border-color: ta.has-hover ? Theme.primary : Theme.outline-variant;
    background: ta.has-hover ? Theme.surface-high : Theme.surface;
    animate background, border-color { duration: 80ms; }
    HorizontalLayout {
        padding-left: Theme.s-3;
        padding-right: Theme.s-3;
        spacing: Theme.s-2;
        alignment: stretch;
        Text {
            text: root.label;
            color: Theme.on-surface;
            font-family: Theme.font-mono;
            font-size: Theme.font-code;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
        Icon {
            glyph: Icons.chevron-right;
            size: 14px;
            tint: ta.has-hover ? Theme.primary : Theme.on-surface-variant;
        }
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

// Compact `[Need User Input · N]` chip — appears on a dashboard session card
// when the session has pending user-input rows. Read-only on cards; the
// session-view variant (QuestionsToggleChip) below is clickable.
component NeedInputChip inherits Rectangle {
    in property <int> count;
    horizontal-stretch: 0;
    border-radius: Theme.radius-default;
    border-width: 1px;
    border-color: Theme.error.with-alpha(0.3);
    background: Theme.error-container.with-alpha(0.2);
    height: 22px;
    HorizontalLayout {
        padding-left: Theme.s-2;
        padding-right: Theme.s-2;
        spacing: Theme.s-1;
        alignment: center;
        Icon { glyph: Icons.warning; size: 11px; tint: Theme.error; }
        Text {
            text: "[Need User Input · " + root.count + "]";
            color: Theme.error;
            font-family: Theme.font-mono;
            font-size: Theme.font-label;
            letter-spacing: Theme.ls-label;
            font-weight: Theme.w-bold;
            vertical-alignment: center;
        }
    }
}

// Session-permission grant indicator + toggle.
// Click → flip grant state. Visual: filled when granted, outlined when not.
// Specific-branch grants render the same as AllBranches for now (binary chip);
// `branches` text shown as tooltip would need richer hover state.
component GrantToggleChip inherits Rectangle {
    in property <string> label;          // "commit" or "push"
    in property <bool>   granted;        // current state from bridge cache
    in property <string> icon: "";
    callback clicked();
    horizontal-stretch: 0;
    border-radius: Theme.radius-default;
    border-width: 1px;
    border-color: granted
        ? Theme.primary.with-alpha(0.5)
        : Theme.outline-variant.with-alpha(0.4);
    background: granted
        ? Theme.primary-container.with-alpha(ta.has-hover ? 0.45 : 0.3)
        : Theme.surface-low.with-alpha(ta.has-hover ? 0.8 : 0.5);
    height: 26px;
    animate border-color, background { duration: 100ms; }
    HorizontalLayout {
        padding-left: Theme.s-2;
        padding-right: Theme.s-2;
        spacing: Theme.s-1;
        alignment: center;
        if root.icon != "":
            Icon {
                glyph: root.icon;
                size: 11px;
                tint: granted ? Theme.primary : Theme.on-surface-variant;
            }
        Text {
            text: root.label;
            color: granted ? Theme.primary : Theme.on-surface-variant;
            font-family: Theme.font-mono;
            font-size: Theme.font-label;
            letter-spacing: Theme.ls-label;
            font-weight: Theme.w-bold;
            vertical-alignment: center;
        }
        Text {
            text: granted ? "ON" : "OFF";
            color: granted ? Theme.primary : Theme.on-surface-variant.with-alpha(0.6);
            font-family: Theme.font-mono;
            font-size: 9px;
            font-weight: Theme.w-bold;
            vertical-alignment: center;
        }
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

// Header chip in the SessionView that toggles the questions tray open/closed.
// Shows the count + a chevron that flips with state.
component QuestionsToggleChip inherits Rectangle {
    in property <int> count;
    in property <bool> open;
    callback clicked();
    horizontal-stretch: 0;
    border-radius: Theme.radius-default;
    border-width: 1px;
    border-color: count > 0
        ? Theme.error.with-alpha(0.4)
        : Theme.outline-variant.with-alpha(0.4);
    background: count > 0
        ? Theme.error-container.with-alpha(ta.has-hover ? 0.35 : 0.2)
        : Theme.surface-low.with-alpha(ta.has-hover ? 0.8 : 0.5);
    height: 26px;
    animate border-color, background { duration: 100ms; }
    HorizontalLayout {
        padding-left: Theme.s-2;
        padding-right: Theme.s-2;
        spacing: Theme.s-1;
        alignment: center;
        Icon {
            glyph: Icons.warning;
            size: 11px;
            tint: count > 0 ? Theme.error : Theme.on-surface-variant;
        }
        Text {
            text: count > 0
                ? "Questions · " + count
                : "Questions";
            color: count > 0 ? Theme.error : Theme.on-surface-variant;
            font-family: Theme.font-mono;
            font-size: Theme.font-label;
            letter-spacing: Theme.ls-label;
            font-weight: Theme.w-bold;
            vertical-alignment: center;
        }
        Text {
            text: open ? "▴" : "▾";
            color: count > 0 ? Theme.error : Theme.on-surface-variant;
            font-size: 10px;
            vertical-alignment: center;
        }
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

// Selectable option chip — used inside QuestionCard for choice-kind. Shows a
// visual selected state instead of immediately firing on click.
component OptionChip inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    callback clicked();
    height: 28px;
    horizontal-stretch: 1;
    border-radius: Theme.radius-lg;
    border-width: selected ? 2px : 1px;
    border-color: selected
        ? Theme.primary
        : ta.has-hover ? Theme.primary.with-alpha(0.6) : Theme.outline-variant;
    background: selected
        ? Theme.primary-fixed.with-alpha(0.2)
        : ta.has-hover ? Theme.surface-high : Theme.surface;
    animate background, border-color, border-width { duration: 80ms; }
    HorizontalLayout {
        padding-left: Theme.s-3;
        padding-right: Theme.s-3;
        spacing: Theme.s-2;
        alignment: stretch;
        Text {
            text: selected ? "● " + root.label : "○ " + root.label;
            color: selected ? Theme.primary : Theme.on-surface;
            font-family: Theme.font-mono;
            font-size: Theme.font-code;
            font-weight: selected ? Theme.w-semi : 400;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

// One card in the tray — owns local `picked` (choice) / `reply` (text input)
// state and notifies AppState via `set-answer` on every change. The tray
// itself is dumb; view_model accumulates per-choice-id values and decides
// when the Send button is enabled.
component QuestionCard inherits Rectangle {
    in property <PendingQuestion> q;
    // Local edit state. `changed` handlers below push every transition to
    // AppState so the Rust-side accumulator stays in sync.
    in-out property <string> picked: "";
    in-out property <string> reply: "";

    changed picked => { AppState.set-answer(q.choice-id, picked); }
    changed reply => { AppState.set-answer(q.choice-id, reply); }

    border-radius: Theme.radius-default;
    border-width: 1px;
    border-color: Theme.outline-variant.with-alpha(0.3);
    background: Theme.surface.with-alpha(0.3);

    VerticalLayout {
        padding: Theme.s-3;
        spacing: Theme.s-2;
        HorizontalLayout {
            spacing: Theme.s-2;
            alignment: stretch;
            Text {
                text: q.kind == "choice" ? "❓ choice"
                    : q.kind == "open_ask" ? "💬 open-ask"
                    : q.kind == "halt" ? "⏸ awaiting" : q.kind;
                color: Theme.on-surface-variant;
                font-family: Theme.font-mono;
                font-size: Theme.font-label;
                letter-spacing: Theme.ls-label;
                font-weight: Theme.w-bold;
                vertical-alignment: center;
                horizontal-stretch: 0;
            }
            Text {
                text: q.agent;
                color: Theme.on-surface-variant;
                font-family: Theme.font-mono;
                font-size: Theme.font-label;
                vertical-alignment: center;
                horizontal-stretch: 0;
            }
            Rectangle { horizontal-stretch: 1; }
            Text {
                text: q.asked-at;
                color: Theme.on-surface-variant;
                font-family: Theme.font-mono;
                font-size: Theme.font-label;
                vertical-alignment: center;
                overflow: elide;
                horizontal-stretch: 0;
            }
        }
        Text {
            text: q.prompt;
            color: Theme.on-surface;
            font-family: Theme.font-mono;
            font-size: Theme.font-code;
            wrap: word-wrap;
        }
        if q.kind == "choice": VerticalLayout {
            spacing: Theme.s-1;
            for opt in q.options:
                OptionChip {
                    label: opt;
                    selected: picked == opt;
                    clicked => { picked = opt; }
                }
        }
        if q.kind == "halt" || q.kind == "open_ask": CustomInput {
            placeholder: q.kind == "halt"
                ? "Type a reply (or leave empty to just resume)..."
                : "Type your answer...";
            text <=> reply;
        }
    }
}

// The expanded list of pending questions inside the SessionView. Renders one
// QuestionCard per pending row + a Send All button that batches the inputs
// and ships them to the agent as a single combined turn.
component QuestionsTray inherits Rectangle {
    in property <[PendingQuestion]> questions;
    in property <bool> submit-ready;
    border-radius: Theme.radius-default;
    border-width: 1px;
    border-color: Theme.outline-variant.with-alpha(0.4);
    background: Theme.surface-low.with-alpha(0.4);
    VerticalLayout {
        padding: Theme.s-3;
        spacing: Theme.s-3;
        for q in root.questions:
            QuestionCard { q: q; }
        // Send-all bar.
        HorizontalLayout {
            spacing: Theme.s-2;
            alignment: end;
            Text {
                text: root.submit-ready
                    ? "Submits answers + clears the tray."
                    : "Pick an option / type a reply on at least one row to enable.";
                color: Theme.on-surface-variant;
                font-family: Theme.font-mono;
                font-size: Theme.font-label;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
            send-btn := Rectangle {
                horizontal-stretch: 0;
                height: 30px;
                min-width: 110px;
                border-radius: Theme.radius-lg;
                border-width: 1px;
                border-color: root.submit-ready
                    ? Theme.primary
                    : Theme.outline-variant.with-alpha(0.3);
                background: root.submit-ready
                    ? (send-ta.has-hover ? Theme.primary-fixed.with-alpha(0.3) : Theme.primary-fixed.with-alpha(0.2))
                    : Theme.surface-low.with-alpha(0.3);
                animate background, border-color { duration: 80ms; }
                HorizontalLayout {
                    padding-left: Theme.s-3;
                    padding-right: Theme.s-3;
                    alignment: center;
                    Text {
                        text: "↑ Send all";
                        color: root.submit-ready ? Theme.primary : Theme.on-surface-variant.with-alpha(0.5);
                        font-family: Theme.font-mono;
                        font-size: Theme.font-code;
                        font-weight: Theme.w-bold;
                        vertical-alignment: center;
                    }
                }
                send-ta := TouchArea {
                    enabled: root.submit-ready;
                    clicked => { AppState.submit-questions-batch(); }
                }
            }
        }
    }
}

component QuickviewRow inherits Rectangle {
    in property <string> quickview;
    background: Theme.surface-lowest;
    Rectangle {
        x: 0; y: 0;
        width: parent.width; height: 1px;
        background: Theme.outline-variant.with-alpha(0.5);
    }
    VerticalLayout {
        padding-top: Theme.s-2;
        padding-bottom: Theme.s-2;
        padding-left: Theme.s-3;
        padding-right: Theme.s-3;
        spacing: 2px;
        Text {
            text: "QUICKVIEW";
            color: Theme.on-surface-variant;
            font-family: Theme.font-mono;
            font-size: Theme.font-label;
            letter-spacing: Theme.ls-label;
            font-weight: Theme.w-bold;
        }
        Text {
            text: root.quickview == "" ? "—" : root.quickview;
            color: Theme.on-surface;
            font-family: Theme.font-mono;
            font-size: Theme.font-code;
            font-italic: true;
            overflow: elide;
            wrap: no-wrap;
        }
    }
}

component SessionTileView inherits Rectangle {
    in property <SessionTile> data;
    callback clicked();
    horizontal-stretch: 1;
    vertical-stretch: 0;
    // Cap so a single tile (or a near-empty dashboard) doesn't stretch to fill
    // the whole pane vertically. Tall content (long quickview / many pending
    // options) clips because `clip: true` is set below.
    max-height: 240px;
    border-radius: Theme.radius-xl;
    border-width: 1px;
    border-color: data.awaiting
        ? Theme.primary
        : ta.has-hover ? Theme.primary-fixed.with-alpha(0.4) : Theme.outline-variant.with-alpha(0.6);
    background: #0f172a;
    clip: true;
    animate border-color { duration: 100ms; }

    VerticalLayout {
        spacing: 0px;
        alignment: start;

        // Top accent stripe — orange when awaiting (clipped by outer radius).
        if data.awaiting: Rectangle {
            height: 3px;
            background: Theme.primary;
        }

        // Body.
        VerticalLayout {
            padding-top: Theme.s-4;
            padding-bottom: Theme.s-3;
            padding-left: Theme.s-4;
            padding-right: Theme.s-4;
            spacing: Theme.s-3;

            // Header: ID + phase chip / timestamp
            HorizontalLayout {
                spacing: Theme.s-2;
                alignment: stretch;
                Text {
                    text: data.id;
                    color: Theme.on-surface-variant;
                    font-family: Theme.font-mono;
                    font-size: Theme.font-code;
                    overflow: elide;
                    vertical-alignment: center;
                    horizontal-stretch: 0;
                }
                if data.phase != "":
                    PhaseChip { phase: data.phase; }
                Rectangle { horizontal-stretch: 1; }
                Text {
                    text: data.last-activity;
                    color: Theme.on-surface-variant;
                    font-family: Theme.font-mono;
                    font-size: Theme.font-code;
                    vertical-alignment: center;
                    horizontal-alignment: right;
                    overflow: elide;
                    horizontal-stretch: 0;
                }
            }

            // Title
            Text {
                text: data.title;
                color: Theme.on-surface;
                font-family: Theme.font-display;
                font-size: Theme.font-head-md;
                font-weight: Theme.w-semi;
                wrap: word-wrap;
            }

            // Need-input chip — replaces the older inline question + buttons.
            // Card stays compact; full content (and answer buttons) live in
            // the per-session questions tray inside SessionView. We show the
            // count chip when there are any pending question rows; otherwise
            // fall back to the static AwaitingBadge for plain awaiting state
            // that wasn't backfilled into the questions table.
            if data.pending-input-count > 0:
                HorizontalLayout {
                    alignment: start;
                    NeedInputChip { count: data.pending-input-count; }
                }
            if data.pending-input-count == 0 && data.awaiting:
                HorizontalLayout {
                    alignment: start;
                    AwaitingBadge {}
                }
        }

        // Quickview footer — always present.
        QuickviewRow { quickview: data.quickview; }
    }

    ta := TouchArea { clicked => { root.clicked(); } }
}

component DashboardEmptyState inherits Rectangle {
    callback create();
    background: transparent;
    height: 240px;
    horizontal-stretch: 1;
    VerticalLayout {
        padding: Theme.s-6;
        spacing: Theme.s-3;
        alignment: center;
        Text {
            text: "No sessions yet";
            color: Theme.on-surface;
            font-family: Theme.font-display;
            font-size: Theme.font-head-md;
            font-weight: Theme.w-semi;
            horizontal-alignment: center;
        }
        Text {
            text: "A session pairs Brian and Rain on a task.";
            color: Theme.on-surface-variant;
            font-family: Theme.font-body;
            font-size: Theme.font-body-md;
            horizontal-alignment: center;
            wrap: word-wrap;
        }
        HorizontalLayout {
            alignment: center;
            padding-top: Theme.s-2;
            PrimaryButton {
                label: "New Session";
                icon: Icons.plus;
                clicked => { root.create(); }
            }
        }
    }
}

component DashboardPane inherits Rectangle {
    background: Theme.bg-canvas;
    VerticalLayout {
        padding-left: Theme.s-6;
        padding-right: Theme.s-6;
        padding-top: Theme.s-6;
        padding-bottom: Theme.s-4;
        spacing: Theme.s-6;

        // Header row.
        HorizontalLayout {
            spacing: Theme.s-3;
            alignment: stretch;
            VerticalLayout {
                alignment: center;
                Text {
                    text: "Active Sessions";
                    color: Theme.on-surface;
                    font-family: Theme.font-display;
                    font-size: Theme.font-head-lg;
                    font-weight: Theme.w-bold;
                    letter-spacing: Theme.ls-headline;
                }
            }
            Rectangle { horizontal-stretch: 1; }
            VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    spacing: Theme.s-2;
                    GhostButton {
                        label: "Filter";
                        icon: Icons.menu;
                        clicked => { /* TODO: filter dropdown */ }
                    }
                    PrimaryButton {
                        label: "New Session";
                        icon: Icons.plus;
                        clicked => {
                            AppState.new-session-title = "";
                            AppState.new-session-project-name = "";
                            AppState.new-session-project-path = "";
                            AppState.new-session-dialog-open = true;
                        }
                    }
                }
            }
        }

        // Tile grid: 3 columns, each a VerticalLayout, filtered by mod(i,3).
        ScrollView {
            vertical-stretch: 1;
            VerticalLayout {
                spacing: Theme.s-3;
                if AppState.sessions.length == 0:
                    DashboardEmptyState {
                        create => {
                            AppState.new-session-title = "";
                            AppState.new-session-project-name = "";
                            AppState.new-session-project-path = "";
                            AppState.new-session-dialog-open = true;
                        }
                    }
                if AppState.sessions.length > 0:
                    // Responsive grid — col-count steps with width like CSS
                    // grid auto-fit. 4 cols on ≥1400px, 3 on ≥1000px, 2 on
                    // ≥640px, 1 below. row/col are computed per-tile using the
                    // index from `for tile[i]`. `vertical-stretch: 0` so the
                    // grid sizes to its natural content height — otherwise the
                    // outer ScrollView (which is v-stretch:1) hands all the
                    // available height down and tiles balloon to fill.
                    grid-wrap := Rectangle {
                        property <int> col-count: root.width > 1400px ? 4
                            : root.width > 1000px ? 3
                            : root.width > 640px ? 2
                            : 1;
                        vertical-stretch: 0;
                        GridLayout {
                            spacing: Theme.s-3;
                            for tile[i] in AppState.sessions:
                                SessionTileView {
                                    row: Math.floor(i / grid-wrap.col-count);
                                    col: i - grid-wrap.col-count * Math.floor(i / grid-wrap.col-count);
                                    data: tile;
                                    clicked => { AppState.open-session(tile.id); }
                                }
                        }
                    }
            }
        }
    }
}

// ---- Session view ----------------------------------------------------------

// One row in the chat stream. Three variants (user / agent / system) drive the
// alignment + stripe placement.
component ChatBubble inherits VerticalLayout {
    in property <ChatMsg> msg;

    property <bool> is-system: msg.kind == "phase_change";
    property <bool> is-user: msg.author == "user";
    property <bool> is-tool: msg.kind == "tool_use" || msg.kind == "tool_result";
    property <color> author-color:
        is-system               ? Theme.outline :
        is-user                 ? Theme.tertiary :
        msg.author == "brian"   ? Theme.primary :
        msg.author == "rain"    ? Theme.secondary :
        msg.author == "emma"    ? Theme.primary :
        Theme.outline;
    property <string> author-label:
        is-system               ? "PHASE" :
        is-user                 ? "USER" :
        msg.author == "brian"   ? "BRIAN" :
        msg.author == "rain"    ? "RAIN" :
        msg.author == "emma"    ? "EMMA" :
        msg.author;
    property <string> author-glyph:
        is-user               ? Icons.target :
        msg.author == "brian" ? Icons.settings :
        msg.author == "rain"  ? Icons.target :
        msg.author == "emma"  ? Icons.target :
        Icons.dot;

    spacing: Theme.s-1;
    horizontal-stretch: 1;
    alignment: start;

    // System banner — centered, bordered chip.
    if is-system: HorizontalLayout {
        alignment: center;
        padding-top: Theme.s-2;
        padding-bottom: Theme.s-2;
        Rectangle {
            horizontal-stretch: 0;
            border-radius: Theme.radius-default;
            border-width: 1px;
            border-color: Theme.outline-variant;
            background: Theme.surface;
            HorizontalLayout {
                padding-left: Theme.s-3;
                padding-right: Theme.s-3;
                padding-top: Theme.s-1;
                padding-bottom: Theme.s-1;
                spacing: Theme.s-2;
                alignment: center;
                Icon { glyph: Icons.refresh; size: 12px; tint: Theme.secondary; }
                Text {
                    text: "PHASE SHIFT: " + msg.content;
                    color: Theme.on-surface-variant;
                    font-family: Theme.font-mono;
                    font-size: Theme.font-code;
                    font-weight: Theme.w-bold;
                    letter-spacing: Theme.ls-label;
                    vertical-alignment: center;
                }
            }
        }
    }

    // User/agent author row.
    if !is-system: HorizontalLayout {
        spacing: Theme.s-2;
        alignment: is-user ? end : start;
        if is-user: Text {
            text: msg.created-at;
            color: Theme.on-surface-variant;
            font-family: Theme.font-mono;
            font-size: Theme.font-code;
            vertical-alignment: center;
        }
        if is-user: Text {
            text: author-label;
            color: author-color;
            font-family: Theme.font-mono;
            font-size: Theme.font-label;
            font-weight: Theme.w-bold;
            letter-spacing: Theme.ls-label;
            vertical-alignment: center;
        }
        if is-user: Icon {
            glyph: author-glyph; size: 12px; tint: author-color;
        }
        if !is-user: Icon {
            glyph: author-glyph; size: 12px; tint: author-color;
        }
        if !is-user: Text {
            text: author-label;
            color: author-color;
            font-family: Theme.font-mono;
            font-size: Theme.font-label;
            font-weight: Theme.w-bold;
            letter-spacing: Theme.ls-label;
            vertical-alignment: center;
        }
        if !is-user: Text {
            text: msg.created-at;
            color: Theme.on-surface-variant;
            font-family: Theme.font-mono;
            font-size: Theme.font-code;
            vertical-alignment: center;
        }
    }

    // User/agent message card.
    if !is-system: HorizontalLayout {
        alignment: is-user ? end : start;
        Rectangle {
            horizontal-stretch: 0;
            max-width: 720px;
            background: #0f172a;
            border-width: 1px;
            border-color: author-color.with-alpha(0.3);
            border-radius: Theme.radius-default;
            HorizontalLayout {
                spacing: 0px;
                // Left stripe for agents.
                if !is-user: Rectangle {
                    width: 3px;
                    horizontal-stretch: 0;
                    background: author-color;
                }
                VerticalLayout {
                    horizontal-stretch: 1;
                    padding: Theme.s-3;
                    spacing: Theme.s-1;
                    TextInput {
                        text: msg.content;
                        read-only: true;
                        wrap: word-wrap;
                        single-line: false;
                        color: is-tool ? Theme.on-surface-variant : Theme.on-surface;
                        font-family: Theme.font-mono;
                        font-size: Theme.font-code;
                        horizontal-alignment: is-user ? right : left;
                        selection-background-color: Theme.primary.with-alpha(0.4);
                        selection-foreground-color: Theme.on-surface;
                    }
                }
                // Right stripe for user.
                if is-user: Rectangle {
                    width: 3px;
                    horizontal-stretch: 0;
                    background: author-color;
                }
            }
        }
    }
}

// Need-User-Input banner — mirrors the dashboard tile's pending-input footer
// so users see the same affordance whether they're at the dashboard or inside
// the session.
// Inline IPAV phase selector — text-only tabs with underline indicator.
component PhasePill inherits Rectangle {
    in property <string> phase;
    in property <string> letter;
    in property <string> name;
    in property <color> tint;
    height: 28px;
    horizontal-stretch: 0;
    background: ta.has-hover ? Theme.surface-high : transparent;
    animate background { duration: 60ms; }
    HorizontalLayout {
        padding-left: Theme.s-3;
        padding-right: Theme.s-3;
        alignment: center;
        spacing: Theme.s-1;
        Text {
            text: root.letter;
            color: AppState.active-phase == root.letter ? root.tint : Theme.on-surface-variant;
            font-family: Theme.font-mono;
            font-size: Theme.font-code;
            font-weight: AppState.active-phase == root.letter ? Theme.w-bold : Theme.w-regular;
            vertical-alignment: center;
        }
    }
    Rectangle {
        x: Theme.s-2;
        y: parent.height - 2px;
        width: parent.width - Theme.s-2 * 2;
        height: 2px;
        background: AppState.active-phase == root.letter ? root.tint : transparent;
    }
    ta := TouchArea { clicked => { AppState.advance-phase(root.phase); } }
}

component PhaseSelector inherits HorizontalLayout {
    spacing: 0px;
    PhasePill { phase: "I"; letter: "I"; name: "Investigate"; tint: Theme.phase-i; }
    PhasePill { phase: "P"; letter: "P"; name: "Plan";        tint: Theme.phase-p; }
    PhasePill { phase: "A"; letter: "A"; name: "Apply";       tint: Theme.phase-a; }
    PhasePill { phase: "V"; letter: "V"; name: "Verify";      tint: Theme.phase-v; }
}

// Clean chatbox input — NOT terminal-style (per user direction).
// Auto-grows from 1 line (36px) up to 4 lines as the user types. Beyond
// 4 lines, an inner Flickable scrolls so the caret stays visible (mirrors
// std-widgets `TextEditBase`). Enter submits; Shift+Enter inserts a newline.
// Outer HorizontalLayout MUST stay `alignment: stretch` — `alignment: end`
// creates a sizing cycle between Rectangle.preferred-width and
// Flickable.width and collapses the box to 0 (regression in 3be5d72).
//
// Why explicit `height` instead of min/max/preferred: Slint's
// HorizontalLayout pins clipping children to their `min-height` rather
// than picking up `preferred-height`, so the auto-grow regressed silently
// (b36a851 added the binding but the layout never honored it). Computing
// `height` directly forces the layout to respect the wrapped content size.
component ChatInput inherits Rectangle {
    in property <string> placeholder: "Type a message...";
    callback submit(string);
    background: transparent;
    HorizontalLayout {
        spacing: Theme.s-2;
        alignment: stretch;
        Rectangle {
            horizontal-stretch: 1;
            // 4 lines of font-code (12px, mono) ≈ 4 × 17px = 68px + Theme.s-2 * 2
            // vertical padding = 84px ceiling. 36px floor = 1 line + padding.
            height: clamp(input.preferred-height + Theme.s-2 * 2, 36px, 84px);
            clip: true;
            border-radius: Theme.radius-lg;
            border-width: 1px;
            border-color: input.has-focus ? Theme.primary : Theme.outline-variant;
            background: Theme.surface;
            animate border-color { duration: 100ms; }
            forward-focus: input;
            scroll := Flickable {
                x: Theme.s-3;
                y: Theme.s-2;
                width: parent.width - Theme.s-3 * 2;
                height: parent.height - Theme.s-2 * 2;
                interactive: true;
                viewport-width: self.width;
                viewport-height: max(self.height, input.preferred-height);
                input := TextInput {
                    width: parent.width;
                    color: Theme.on-surface;
                    font-family: Theme.font-mono;
                    font-size: Theme.font-code;
                    single-line: false;
                    wrap: word-wrap;
                    page-height: scroll.height;
                    selection-background-color: Theme.primary.with-alpha(0.4);
                    selection-foreground-color: Theme.on-surface;
                    key-pressed(ev) => {
                        if (ev.text == Key.Return && !ev.modifiers.shift) {
                            if (self.text != "") {
                                root.submit(self.text);
                                self.text = "";
                            }
                            return accept;
                        }
                        return reject;
                    }
                    // Keep caret inside the Flickable viewport. viewport-y is
                    // non-positive; cpos.y is in TextInput's own coords (=
                    // viewport coords here since TextInput fills the viewport).
                    // 20px margin ≈ one font-code line height + breathing room.
                    cursor-position-changed(cpos) => {
                        if (cpos.y + scroll.viewport-y < 0) {
                            scroll.viewport-y = -cpos.y;
                        } else if (cpos.y + scroll.viewport-y > scroll.height - 20px) {
                            scroll.viewport-y = min(0px, scroll.height - cpos.y - 20px);
                        }
                    }
                }
            }
            if input.text == "" && !input.has-focus:
                Text {
                    x: Theme.s-3;
                    y: Theme.s-2;
                    width: parent.width - Theme.s-3 * 2;
                    text: root.placeholder;
                    color: Theme.on-surface-variant.with-alpha(0.55);
                    font-family: Theme.font-mono;
                    font-size: Theme.font-code;
                    vertical-alignment: top;
                }
        }
        PrimaryButton {
            label: "Send";
            icon: Icons.play;
            btn-height: 36px;
            clicked => {
                if (input.text != "") {
                    root.submit(input.text);
                    input.text = "";
                }
            }
        }
    }
}

component SessionView inherits Rectangle {
    background: Theme.bg-canvas;
    VerticalLayout {
        spacing: 0px;
        VerticalLayout {
            vertical-stretch: 1;
            padding-left: Theme.s-6;
            padding-right: Theme.s-6;
            padding-top: Theme.s-4;
            padding-bottom: Theme.s-3;
            spacing: Theme.s-4;

                    // Session header — title + initialized line + status chip.
                    Rectangle {
                        Rectangle {
                            x: 0; y: parent.height - 1px;
                            width: parent.width; height: 1px;
                            background: Theme.outline-variant;
                        }
                        HorizontalLayout {
                            padding-bottom: Theme.s-3;
                            spacing: Theme.s-3;
                            alignment: stretch;
                            VerticalLayout {
                                spacing: 2px;
                                horizontal-stretch: 1;
                                HorizontalLayout {
                                    spacing: Theme.s-2;
                                    alignment: start;
                                    GhostButton {
                                        label: "Back";
                                        icon: Icons.arrow-left;
                                        btn-height: 24px;
                                        clicked => { AppState.back-to-dashboard(); }
                                    }
                                    Icon { glyph: Icons.hash; size: 18px; tint: Theme.primary; }
                                    Text {
                                        text: AppState.active-title == "" ? AppState.active-session-id : AppState.active-title;
                                        color: Theme.on-surface;
                                        font-family: Theme.font-display;
                                        font-size: Theme.font-head-md;
                                        font-weight: Theme.w-semi;
                                        overflow: elide;
                                        vertical-alignment: center;
                                    }
                                }
                                Text {
                                    text: "SESSION " + AppState.active-session-id;
                                    color: Theme.on-surface-variant;
                                    font-family: Theme.font-mono;
                                    font-size: Theme.font-code;
                                    letter-spacing: Theme.ls-label;
                                }
                            }
                            VerticalLayout {
                                alignment: end;
                                spacing: Theme.s-2;
                                horizontal-stretch: 0;
                                HorizontalLayout {
                                    spacing: Theme.s-2;
                                    alignment: end;
                                    // Commit / push session-grant chips. Click toggles. ON =
                                    // agents skip request_approval for that action; OFF =
                                    // default per-action gate.
                                    GrantToggleChip {
                                        label: "COMMIT";
                                        granted: AppState.active-commit-granted;
                                        clicked => {
                                            AppState.set-session-permission("commit", !AppState.active-commit-granted);
                                        }
                                    }
                                    GrantToggleChip {
                                        label: "PUSH";
                                        granted: AppState.active-push-granted;
                                        clicked => {
                                            AppState.set-session-permission("push", !AppState.active-push-granted);
                                        }
                                    }
                                    // Questions toggle — chip showing pending count + chevron.
                                    // Always visible (even when count=0) so the user knows where
                                    // to look if questions accumulate during the session.
                                    QuestionsToggleChip {
                                        count: AppState.active-questions.length;
                                        open: AppState.questions-tray-open;
                                        clicked => {
                                            AppState.questions-tray-open = !AppState.questions-tray-open;
                                        }
                                    }
                                    if AppState.active-phase != "":
                                        LabelChip {
                                            label: AppState.active-phase == "I" ? "INVESTIGATING"
                                                : AppState.active-phase == "P" ? "PLANNING"
                                                : AppState.active-phase == "A" ? "APPLYING"
                                                : AppState.active-phase == "V" ? "VERIFYING"
                                                : "—";
                                            tint:
                                                AppState.active-phase == "I" ? Theme.phase-i :
                                                AppState.active-phase == "P" ? Theme.phase-p :
                                                AppState.active-phase == "A" ? Theme.phase-a :
                                                AppState.active-phase == "V" ? Theme.phase-v :
                                                Theme.on-surface-variant;
                                            dot: true;
                                        }
                                }
                                VerticalLayout {
                                    alignment: end;
                                    PhaseSelector {}
                                }
                            }
                        }
                    }

                    // Models actually running in this session — frozen at spawn,
                    // so it reflects what's talking even if the user edited the
                    // agent_configs row mid-session.
                    if AppState.active-brian-model != "" || AppState.active-rain-model != "":
                        HorizontalLayout {
                            spacing: Theme.s-5;
                            alignment: start;
                            Text {
                                text: "Brian · HANDS → " + (AppState.active-brian-model == "" ? "(unknown)" : AppState.active-brian-model);
                                color: Theme.on-surface-variant;
                                font-family: Theme.font-mono;
                                font-size: Theme.font-code;
                            }
                            Text {
                                text: "Rain · EYES → " + (AppState.active-rain-model == "" ? "(unknown)" : AppState.active-rain-model);
                                color: Theme.on-surface-variant;
                                font-family: Theme.font-mono;
                                font-size: Theme.font-code;
                            }
                        }

                    // Questions tray — sole source of truth for ALL questions
                    // (choice + halt + open_ask). Toggle via the header chip.
                    if AppState.questions-tray-open && AppState.active-questions.length > 0:
                        QuestionsTray {
                            questions: AppState.active-questions;
                            submit-ready: AppState.submit-ready;
                        }

                    // Chat stream.
                    Rectangle {
                        vertical-stretch: 1;
                        background: Theme.bg-canvas;
                        session-sv := ScrollView {
                            // Local alias on global tick. Slint maintainer's
                            // formula from GH#2301: clamp to ≤ 0 since
                            // viewport-y is non-positive when scrolled.
                            property <int> scroll-tick: AppState.session-scroll-tick;
                            changed scroll-tick => {
                                session-sv.viewport-y = min(0px, -session-sv.viewport-height + session-sv.visible-height);
                            }
                            VerticalLayout {
                                padding-bottom: Theme.s-4;
                                spacing: Theme.s-4;
                                alignment: start;
                                for msg in AppState.session-msgs:
                                    ChatBubble { msg: msg; }
                                if AppState.session-msgs.length == 0:
                                    Rectangle {
                                        height: 160px;
                                        VerticalLayout {
                                            alignment: center;
                                            Text {
                                                text: "Session ready. Type a message to start.";
                                                color: Theme.on-surface-variant;
                                                font-family: Theme.font-mono;
                                                font-size: Theme.font-code;
                                                horizontal-alignment: center;
                                            }
                                        }
                                    }
                            }
                        }
                    }

            // Chat input.
            ChatInput {
                placeholder: "Type a message...";
                submit(t) => { AppState.broadcast(t); }
            }
        }
    }
}

// ---- Context Library -------------------------------------------------------

component CLTreeRow inherits Rectangle {
    in property <CLFileEntry> entry;
    in property <bool> active;
    in property <bool> editing;
    callback clicked();
    callback toggle-collapse();
    callback create-file-here();
    callback create-folder-here();
    callback rename-self();
    callback delete-self();
    callback commit-edit();
    callback cancel-edit();
    height: 26px;
    // Fill the sidebar width. Without horizontal-stretch the parent
    // VerticalLayout sizes each row to its content's preferred width
    // (chevron + icon + display-name) and centers it — that's the
    // "center-justified" look. Stretching anchors the row left so the
    // chevron + icon + label sit at fixed offsets regardless of text length.
    horizontal-stretch: 1;
    min-width: 0;
    border-radius: Theme.radius-default;
    background: root.editing
        ? Theme.primary-container.with-alpha(0.35)
        : root.active
            ? Theme.primary-container.with-alpha(0.2)
            : ta.has-hover ? Theme.surface-high
            : transparent;
    border-width: root.editing || root.active ? 1px : 0px;
    border-color: root.editing
        ? Theme.primary
        : root.active ? Theme.primary.with-alpha(0.4) : transparent;
    animate background, border-color { duration: 60ms; }
    // Auto-focus for the inline edit-input was attempted via Timer but
    // crashed accesskit on commit: when the user hits Enter the ghost
    // row is destroyed (walker no longer emits it once editing-mode
    // clears), and the accesskit consumer panics because the focused
    // node has vanished from the tree. User clicks once to focus the
    // input; finding a safe auto-focus pattern is a follow-up — likely
    // requires explicitly transferring focus to a stable element
    // BEFORE the row gets removed.
    // Native context menu. Slint's ContextMenuArea normally opens on
    // right-click automatically, but a nested TouchArea consumes the
    // pointer event before ContextMenuArea sees it. Workaround: TouchArea
    // dispatches the right-click itself via cm.show(coord). Left-click
    // still goes through the `clicked` path normally.
    cm := ContextMenuArea {
        Menu {
            MenuItem {
                title: entry.is-dir ? "Toggle expand" : "Open";
                activated => { root.clicked(); }
            }
            MenuItem {
                title: "New file here";
                enabled: entry.is-dir && !entry.is-ghost;
                activated => { root.create-file-here(); }
            }
            MenuItem {
                title: "New folder here";
                enabled: entry.is-dir && !entry.is-ghost;
                activated => { root.create-folder-here(); }
            }
            MenuItem {
                title: "Rename";
                enabled: !entry.is-ghost;
                activated => { root.rename-self(); }
            }
            MenuItem {
                title: "Delete";
                enabled: !entry.is-ghost;
                activated => { root.delete-self(); }
            }
        }
        HorizontalLayout {
            padding-left: entry.depth * Theme.s-3 + Theme.s-2;
            padding-right: Theme.s-2;
            spacing: Theme.s-2;
            alignment: stretch;
            // Chevron / file glyph. Folders get a clickable chevron that
            // toggles collapse; files get a passive bullet.
            Rectangle {
                width: 14px;
                horizontal-stretch: 0;
                Icon {
                    // Folder uses pure-ASCII chevron pair (>/v) so it renders
                    // on any mono font; files just show "-".
                    glyph: entry.is-dir
                        ? (entry.expanded ? Icons.chevron-down : Icons.chevron-right)
                        : Icons.dot;
                    size: 11px;
                    tint: entry.is-dir ? Theme.on-surface-variant : Theme.on-surface-variant.with-alpha(0.5);
                }
                if entry.is-dir && !entry.is-ghost: TouchArea {
                    clicked => { root.toggle-collapse(); }
                }
            }
            // Registered-project marker slot. Always present (fixed width)
            // so the label's x-position is stable regardless of whether the
            // row carries a lightbulb — without the reserved slot, label
            // start jitters between registered/non-registered folders.
            Rectangle {
                width: 14px;
                horizontal-stretch: 0;
                if entry.is-dir && entry.is-registered-project: Icon {
                    glyph: Icons.lightbulb;
                    size: 12px;
                    tint: Theme.primary;
                }
            }
            // Label OR inline edit input depending on mode. TextInput is
            // ALWAYS rendered (just hidden when not editing) so:
            //   1. `forward-focus` always has a valid target — clicks on
            //      this Rectangle delegate focus to the input
            //   2. Slint's LineEdit-style focus dispatch works
            //      (matches the std widget pattern in lineedit-base.slint)
            //
            // The Text + TextInput explicitly fill the parent Rectangle's
            // width (x: 0; width: parent.width) and pin horizontal-alignment:
            // left. Without this slint sizes the Text/TextInput to their
            // preferred (content) width AND centers them inside the wider
            // stretched Rectangle — that's what produced the "text appears
            // centered" look when the row stretched to fill the sidebar.
            Rectangle {
                horizontal-stretch: 1;
                min-width: 0;
                clip: true;
                forward-focus: edit-input;
                if !root.editing: Text {
                    x: 0;
                    y: 0;
                    width: parent.width;
                    height: parent.height;
                    text: entry.display-name;
                    color: root.active
                        ? Theme.primary
                        : entry.is-dir && entry.is-registered-project
                            ? Theme.primary
                            : entry.is-dir ? Theme.on-surface : Theme.on-surface-variant;
                    font-family: Theme.font-mono;
                    font-size: Theme.font-code;
                    font-weight: entry.is-dir ? Theme.w-bold : Theme.w-regular;
                    horizontal-alignment: left;
                    vertical-alignment: center;
                    overflow: elide;
                }
                edit-input := TextInput {
                    visible: root.editing;
                    x: 0;
                    y: 0;
                    width: parent.width;
                    height: parent.height;
                    text <=> AppState.cl-tree-editing-name;
                    color: Theme.on-surface;
                    font-family: Theme.font-mono;
                    font-size: Theme.font-code;
                    horizontal-alignment: left;
                    vertical-alignment: center;
                    single-line: true;
                    selection-background-color: Theme.primary.with-alpha(0.4);
                    // Handle Enter + Escape explicitly here. Relying on the
                    // built-in `accepted` callback was flaky because the
                    // `key-pressed` handler intercepts Enter first; returning
                    // reject didn't reliably route to accepted afterwards.
                    key-pressed(ev) => {
                        if (ev.text == Key.Return) {
                            root.commit-edit();
                            return accept;
                        }
                        if (ev.text == Key.Escape) {
                            root.cancel-edit();
                            return accept;
                        }
                        return reject;
                    }
                }
            }
        }
        ta := TouchArea {
            // Step aside when the inline editor is up — otherwise this
            // sibling sits on top of the HorizontalLayout, swallows the
            // user's click before the TextInput can focus, and the row
            // looks inert.
            enabled: !root.editing;
            pointer-event(ev) => {
                if (ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left) {
                    root.clicked();
                }
                if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.right) {
                    cm.show({ x: self.mouse-x, y: self.mouse-y });
                }
            }
        }
    }
}

component ContextLibraryPane inherits Rectangle {
    background: Theme.bg-canvas;
    HorizontalLayout {
        spacing: 0px;

        // Sidebar — width is drag-resizable via the handle on its right edge.
        // Clamped to [180px, 600px] so the user can't shrink it past usability
        // or balloon it to fill the screen.
        sidebar := Rectangle {
            width: AppState.cl-sidebar-width;
            background: Theme.surface-lowest;
            Rectangle {
                x: parent.width - 1px; y: 0;
                width: 1px; height: parent.height;
                background: Theme.outline-variant;
            }
            // Drag handle. Sits on top of the divider, 6px wide for an easy
            // grab target. ew-resize cursor signals it's draggable. Width
            // mutates `cl-sidebar-width` during drag.
            Rectangle {
                x: parent.width - 3px; y: 0;
                width: 6px; height: parent.height;
                background: resize-ta.has-hover || resize-ta.pressed
                    ? Theme.primary.with-alpha(0.4)
                    : transparent;
                animate background { duration: 80ms; }
                resize-ta := TouchArea {
                    mouse-cursor: ew-resize;
                    moved => {
                        if (self.pressed) {
                            // delta = mouse-x minus pressed-x; both relative
                            // to this handle Rectangle. Apply to width and
                            // clamp.
                            AppState.cl-sidebar-width = max(180px,
                                min(600px,
                                    AppState.cl-sidebar-width + (self.mouse-x - self.pressed-x)));
                        }
                    }
                }
            }
            VerticalLayout {
                padding-left: Theme.s-3;
                padding-right: Theme.s-3;
                padding-top: Theme.s-4;
                padding-bottom: Theme.s-3;
                spacing: Theme.s-3;
                // Right-click on this header → root-level context menu.
                // Lets the user create files/folders at the bot-hq root
                // (e.g. alongside general-rules.md) without needing to
                // right-click on an existing folder.
                header-cm := ContextMenuArea {
                    Menu {
                        MenuItem {
                            title: "New file at root";
                            activated => { AppState.cl-tree-begin-create-file(""); }
                        }
                        MenuItem {
                            title: "New folder at root";
                            activated => { AppState.cl-tree-begin-create-folder(""); }
                        }
                        MenuItem {
                            title: "Refresh";
                            activated => {
                                AppState.cl-rescan();
                                AppState.cl-refresh();
                            }
                        }
                    }
                    HorizontalLayout {
                        spacing: Theme.s-2;
                        Text {
                            text: "LIBRARY TREE";
                            color: Theme.on-surface-variant;
                            font-family: Theme.font-mono;
                            font-size: Theme.font-label;
                            letter-spacing: Theme.ls-label;
                            font-weight: Theme.w-bold;
                            vertical-alignment: center;
                        }
                        Rectangle { horizontal-stretch: 1; }
                        IconButton {
                            glyph: Icons.plus;
                            size: 14px;
                            clicked => {
                                AppState.cl-tree-begin-create-file("");
                            }
                        }
                        // Single Refresh button = rescan disk + repaint tree.
                        IconButton {
                            glyph: Icons.refresh;
                            size: 11px;
                            clicked => {
                                AppState.cl-rescan();
                                AppState.cl-refresh();
                            }
                        }
                    }
                    // ContextMenuArea also needs a TouchArea sibling to dispatch
                    // right-click manually — same pattern as the row, the
                    // surrounding layout otherwise consumes the pointer event
                    // before ContextMenuArea's native handler sees it.
                    TouchArea {
                        pointer-event(ev) => {
                            if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.right) {
                                header-cm.show({ x: self.mouse-x, y: self.mouse-y });
                            }
                        }
                    }
                }
                ScrollView {
                    vertical-stretch: 1;
                    VerticalLayout {
                        spacing: 1px;
                        for entry in AppState.cl-tree:
                            CLTreeRow {
                                entry: entry;
                                active: entry.relative-path == AppState.cl-current-path;
                                // For new-file / new-folder modes the
                                // editing-path stores the PARENT dir — but
                                // the actual input lives on the ghost row,
                                // not the parent. Only flip to edit-mode
                                // when (a) this is the ghost row, or (b)
                                // we're in rename mode and the path
                                // matches. Without this, the parent folder
                                // also swaps its label for a TextInput and
                                // appears blank.
                                editing: entry.is-ghost
                                          || (AppState.cl-tree-editing-mode == "rename"
                                              && entry.relative-path == AppState.cl-tree-editing-path);
                                clicked => {
                                    if (entry.is-ghost) {
                                        // No-op — ghost rows are placeholders.
                                    } else if (entry.is-dir) {
                                        // Folders toggle their tree expansion
                                        // AND open the folder-view in the
                                        // right pane. The two surfaces are
                                        // independent: the tree shows what's
                                        // inside, the right pane shows the
                                        // folder's description + project
                                        // metadata.
                                        AppState.cl-tree-toggle-collapse(entry.relative-path);
                                        AppState.cl-open-folder(entry.relative-path);
                                    } else {
                                        AppState.cl-open-file(entry.relative-path);
                                    }
                                }
                                toggle-collapse => { AppState.cl-tree-toggle-collapse(entry.relative-path); }
                                create-file-here => { AppState.cl-tree-begin-create-file(entry.relative-path); }
                                create-folder-here => { AppState.cl-tree-begin-create-folder(entry.relative-path); }
                                rename-self => { AppState.cl-tree-begin-rename(entry.relative-path); }
                                delete-self => { AppState.cl-tree-delete-path(entry.relative-path); }
                                commit-edit => { AppState.cl-tree-commit-edit(); }
                                cancel-edit => { AppState.cl-tree-cancel-edit(); }
                            }
                    }
                }
            }
        }

        // Editor / folder-view. Mutually exclusive: a non-empty
        // cl-current-folder hides the file editor and renders CLFolderView;
        // opening a file (cl-open-file) clears cl-current-folder + vice versa
        // in the view-model handlers so the two never overlap.
        Rectangle {
            background: Theme.bg-canvas;
            horizontal-stretch: 1;
            // ---- Folder view ----
            if AppState.cl-current-folder != "":
                VerticalLayout {
                    spacing: 0px;

                    // Header strip — folder name + path + lightbulb if it's
                    // a registered project. Mirrors the file editor's tab
                    // bar layout so the right pane stays visually consistent.
                    Rectangle {
                        background: Theme.surface-lowest;
                        height: 40px;
                        Rectangle {
                            x: 0; y: parent.height - 1px;
                            width: parent.width; height: 1px;
                            background: Theme.outline-variant;
                        }
                        HorizontalLayout {
                            padding-left: Theme.s-4;
                            padding-right: Theme.s-4;
                            spacing: Theme.s-3;
                            alignment: stretch;
                            HorizontalLayout {
                                spacing: Theme.s-2;
                                alignment: start;
                                Icon {
                                    glyph: AppState.cl-current-folder-is-project
                                        ? Icons.lightbulb
                                        : Icons.folder;
                                    size: 14px;
                                    tint: AppState.cl-current-folder-is-project
                                        ? Theme.primary
                                        : Theme.on-surface-variant;
                                }
                                Text {
                                    text: AppState.cl-current-folder;
                                    color: AppState.cl-current-folder-is-project
                                        ? Theme.primary
                                        : Theme.on-surface;
                                    font-family: Theme.font-mono;
                                    font-size: Theme.font-code;
                                    font-weight: Theme.w-bold;
                                    vertical-alignment: center;
                                }
                                if AppState.cl-current-folder-dirty: Text {
                                    text: "*";
                                    color: Theme.primary;
                                    font-family: Theme.font-mono;
                                    font-size: Theme.font-body-md;
                                    font-weight: Theme.w-bold;
                                    vertical-alignment: center;
                                }
                            }
                            Rectangle { horizontal-stretch: 1; }
                            VerticalLayout {
                                alignment: center;
                                HorizontalLayout {
                                    spacing: Theme.s-3;
                                    alignment: end;
                                    if AppState.cl-current-folder-dirty: Text {
                                        text: "UNSAVED CHANGES";
                                        color: Theme.primary;
                                        font-family: Theme.font-mono;
                                        font-size: Theme.font-label;
                                        letter-spacing: Theme.ls-label;
                                        font-weight: Theme.w-bold;
                                        vertical-alignment: center;
                                    }
                                    PrimaryButton {
                                        label: "Save Description";
                                        icon: Icons.check;
                                        btn-height: 26px;
                                        clicked => {
                                            AppState.cl-save-folder-description();
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // Body — description editor + register/unregister panel.
                    Rectangle {
                        vertical-stretch: 1;
                        background: Theme.bg-canvas;
                        VerticalLayout {
                            padding: Theme.s-4;
                            spacing: Theme.s-4;
                            // Description editor.
                            VerticalLayout {
                                spacing: Theme.s-2;
                                HorizontalLayout {
                                    spacing: Theme.s-2;
                                    Text {
                                        text: "DESCRIPTION";
                                        color: Theme.on-surface-variant;
                                        font-family: Theme.font-mono;
                                        font-size: Theme.font-label;
                                        letter-spacing: Theme.ls-label;
                                        font-weight: Theme.w-bold;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                    }
                                    IconButton {
                                        glyph: Icons.sparkles;
                                        size: 12px;
                                        clicked => { AppState.cl-autodescribe-folder(); }
                                    }
                                }
                                Rectangle {
                                    height: 140px;
                                    border-radius: Theme.radius-lg;
                                    border-width: 1px;
                                    border-color: folder-desc-edit.has-focus
                                        ? Theme.primary
                                        : Theme.outline-variant;
                                    background: Theme.surface-lowest;
                                    animate border-color { duration: 100ms; }
                                    forward-focus: folder-desc-edit;
                                    VerticalLayout {
                                        padding: Theme.s-3;
                                        folder-desc-edit := TextEdit {
                                            text <=> AppState.cl-current-folder-description;
                                            font-family: Theme.font-mono;
                                            font-size: Theme.font-code;
                                            edited => {
                                                AppState.cl-current-folder-dirty = true;
                                            }
                                        }
                                    }
                                }
                            }

                            // Project registration panel.
                            Rectangle {
                                border-radius: Theme.radius-lg;
                                border-width: 1px;
                                border-color: AppState.cl-current-folder-is-project
                                    ? Theme.primary.with-alpha(0.5)
                                    : Theme.outline-variant;
                                background: Theme.surface-lowest;
                                VerticalLayout {
                                    padding: Theme.s-4;
                                    spacing: Theme.s-3;
                                    HorizontalLayout {
                                        spacing: Theme.s-2;
                                        alignment: start;
                                        Icon {
                                            glyph: Icons.lightbulb;
                                            size: 14px;
                                            tint: AppState.cl-current-folder-is-project
                                                ? Theme.primary
                                                : Theme.on-surface-variant;
                                        }
                                        Text {
                                            text: AppState.cl-current-folder-is-project
                                                ? "REGISTERED PROJECT"
                                                : "NOT A PROJECT";
                                            color: AppState.cl-current-folder-is-project
                                                ? Theme.primary
                                                : Theme.on-surface-variant;
                                            font-family: Theme.font-mono;
                                            font-size: Theme.font-label;
                                            letter-spacing: Theme.ls-label;
                                            font-weight: Theme.w-bold;
                                            vertical-alignment: center;
                                            horizontal-stretch: 1;
                                        }
                                    }
                                    if AppState.cl-current-folder-is-project:
                                        VerticalLayout {
                                            spacing: Theme.s-1;
                                            Text {
                                                text: "name · " + AppState.cl-current-folder-project-name;
                                                color: Theme.on-surface;
                                                font-family: Theme.font-mono;
                                                font-size: Theme.font-code;
                                            }
                                            Text {
                                                text: AppState.cl-current-folder-working-repo == ""
                                                    ? "working repo · (unset)"
                                                    : "working repo · " + AppState.cl-current-folder-working-repo;
                                                color: Theme.on-surface-variant;
                                                font-family: Theme.font-mono;
                                                font-size: Theme.font-code;
                                                overflow: elide;
                                            }
                                        }
                                    if !AppState.cl-current-folder-is-project:
                                        Text {
                                            text: "Promote this folder to a first-class project so it shows up in the New Session picker and gets its own CL annotations + policy slot.";
                                            color: Theme.on-surface-variant;
                                            font-family: Theme.font-mono;
                                            font-size: Theme.font-code;
                                            wrap: word-wrap;
                                        }
                                    HorizontalLayout {
                                        alignment: end;
                                        spacing: Theme.s-2;
                                        if AppState.cl-current-folder-is-project:
                                            GhostButton {
                                                label: "Unregister";
                                                icon: Icons.x;
                                                clicked => {
                                                    AppState.cl-unregister-project();
                                                }
                                            }
                                        if !AppState.cl-current-folder-is-project:
                                            PrimaryButton {
                                                label: "Register as Project";
                                                icon: Icons.lightbulb;
                                                btn-height: 30px;
                                                clicked => {
                                                    AppState.cl-register-project-open();
                                                }
                                            }
                                    }
                                }
                            }
                        }
                    }
                }
            // ---- File view (existing) ----
            if AppState.cl-current-folder == "":
            VerticalLayout {
                spacing: 0px;

                // Tab bar.
                Rectangle {
                    background: Theme.surface-lowest;
                    height: 40px;
                    Rectangle {
                        x: 0; y: parent.height - 1px;
                        width: parent.width; height: 1px;
                        background: Theme.outline-variant;
                    }
                    HorizontalLayout {
                        padding-left: Theme.s-4;
                        padding-right: Theme.s-4;
                        spacing: Theme.s-3;
                        alignment: stretch;
                        HorizontalLayout {
                            spacing: Theme.s-2;
                            alignment: start;
                            Icon { glyph: Icons.dot; size: 12px; tint: Theme.primary; }
                            Text {
                                text: AppState.cl-current-path == "" ? "Select a file" : AppState.cl-current-path;
                                color: Theme.on-surface;
                                font-family: Theme.font-mono;
                                font-size: Theme.font-code;
                                vertical-alignment: center;
                            }
                            if AppState.cl-dirty: Text {
                                text: "*";
                                color: Theme.primary;
                                font-family: Theme.font-mono;
                                font-size: Theme.font-body-md;
                                font-weight: Theme.w-bold;
                                vertical-alignment: center;
                            }
                        }
                        Rectangle { horizontal-stretch: 1; }
                        VerticalLayout {
                            alignment: center;
                            HorizontalLayout {
                                spacing: Theme.s-3;
                                alignment: end;
                                if AppState.cl-dirty || AppState.cl-metadata-dirty: Text {
                                    text: "UNSAVED CHANGES";
                                    color: Theme.primary;
                                    font-family: Theme.font-mono;
                                    font-size: Theme.font-label;
                                    letter-spacing: Theme.ls-label;
                                    font-weight: Theme.w-bold;
                                    vertical-alignment: center;
                                }
                                if AppState.cl-current-path != "":
                                    IconButton {
                                        // ASCII "x" — drag-net glyph "✕" was
                                        // showing as a .notdef box on some
                                        // host fonts.
                                        glyph: Icons.x;
                                        size: 12px;
                                        clicked => {
                                            AppState.cl-delete-confirm-path = AppState.cl-current-path;
                                        }
                                    }
                                PrimaryButton {
                                    label: "Save Changes";
                                    icon: Icons.check;
                                    btn-height: 26px;
                                    clicked => { AppState.cl-save-current(); }
                                }
                            }
                        }
                    }
                }

                // Metadata strip — index entry's description + tags. Edits here
                // mark metadata-dirty; Save Changes commits body + metadata atomically.
                if AppState.cl-current-path != "":
                    Rectangle {
                        background: Theme.surface-lowest;
                        Rectangle {
                            x: 0; y: parent.height - 1px;
                            width: parent.width; height: 1px;
                            background: Theme.outline-variant;
                        }
                        VerticalLayout {
                            padding-left: Theme.s-4;
                            padding-right: Theme.s-4;
                            padding-top: Theme.s-2;
                            padding-bottom: Theme.s-2;
                            spacing: Theme.s-1;
                            HorizontalLayout {
                                spacing: Theme.s-2;
                                alignment: stretch;
                                Text {
                                    text: "DESCRIPTION";
                                    color: Theme.on-surface-variant;
                                    font-family: Theme.font-mono;
                                    font-size: Theme.font-label;
                                    letter-spacing: Theme.ls-label;
                                    font-weight: Theme.w-bold;
                                    vertical-alignment: center;
                                    horizontal-stretch: 0;
                                    width: 90px;
                                }
                                // URL-bar style single-line input with
                                // cursor-driven horizontal auto-scroll.
                                // Pattern lifted from Slint stdlib
                                // LineEditBase (widgets/common/lineedit-base.slint):
                                // - TextInput.width grows with content
                                //   (preferred-width) but never below the
                                //   visible area. This is what enables the
                                //   internal scroll — pegging width to the
                                //   visible area kills auto-scroll because
                                //   the TextInput has no overflow to chase.
                                // - TextInput.x is clamped so the right edge
                                //   never exits the right padding inset.
                                // - computed-x is updated by
                                //   cursor-position-changed to slide the
                                //   visible window onto the cursor.
                                // - Outer Rectangle has clip: true so the
                                //   overflowing TextInput is masked to its
                                //   visible area.
                                desc-input := Rectangle {
                                    horizontal-stretch: 1;
                                    height: 32px;
                                    min-width: 1px;
                                    clip: true;
                                    border-radius: Theme.radius-lg;
                                    border-width: 1px;
                                    border-color: desc-edit.has-focus ? Theme.primary : Theme.outline-variant;
                                    background: Theme.surface-lowest;
                                    animate border-color { duration: 100ms; }
                                    forward-focus: desc-edit;
                                    desc-edit := TextInput {
                                        property <length> computed-x;

                                        x: Theme.s-3 + min(0px, max(parent.width - 2 * Theme.s-3 - self.width - self.text-cursor-width, self.computed-x));
                                        y: 0;
                                        width: max(parent.width - 2 * Theme.s-3 - self.text-cursor-width, self.preferred-width);
                                        height: parent.height;
                                        min-width: 0;
                                        text <=> AppState.cl-current-description;
                                        color: Theme.on-surface;
                                        font-family: Theme.font-mono;
                                        font-size: Theme.font-code;
                                        vertical-alignment: center;
                                        single-line: true;
                                        selection-background-color: Theme.primary.with-alpha(0.4);
                                        edited => { AppState.cl-metadata-dirty = true; }
                                        cursor-position-changed(cursor-position) => {
                                            if cursor-position.x + self.computed-x < 0 {
                                                self.computed-x = -cursor-position.x;
                                            } else if cursor-position.x + self.computed-x > parent.width - 2 * Theme.s-3 - self.text-cursor-width {
                                                self.computed-x = parent.width - 2 * Theme.s-3 - self.text-cursor-width - cursor-position.x;
                                            }
                                        }
                                    }
                                    if AppState.cl-current-description == "" && !desc-edit.has-focus:
                                        Text {
                                            x: Theme.s-3;
                                            y: 0;
                                            width: parent.width - 2 * Theme.s-3;
                                            height: parent.height;
                                            text: "what is this file about? agents read this to decide if relevant";
                                            color: Theme.on-surface-variant.with-alpha(0.5);
                                            font-family: Theme.font-mono;
                                            font-size: Theme.font-code;
                                            vertical-alignment: center;
                                            overflow: elide;
                                        }
                                }
                                IconButton {
                                    // ASCII "?" — sparkles "✨" missing in
                                    // most non-emoji mono fonts. "?" reads
                                    // as "ask AI to describe".
                                    glyph: Icons.sparkles;
                                    size: 12px;
                                    clicked => { AppState.cl-autodescribe(); }
                                }
                            }
                            HorizontalLayout {
                                spacing: Theme.s-2;
                                alignment: stretch;
                                Text {
                                    text: "TAGS";
                                    color: Theme.on-surface-variant;
                                    font-family: Theme.font-mono;
                                    font-size: Theme.font-label;
                                    letter-spacing: Theme.ls-label;
                                    font-weight: Theme.w-bold;
                                    vertical-alignment: center;
                                    horizontal-stretch: 0;
                                    width: 90px;
                                }
                                CustomInput {
                                    text <=> AppState.cl-current-tags;
                                    placeholder: "optional. comma-separated hooks: PR-382, schema-v3";
                                    edited => { AppState.cl-metadata-dirty = true; }
                                    horizontal-stretch: 1;
                                }
                            }
                        }
                    }

                // Editor area.
                Rectangle {
                    vertical-stretch: 1;
                    background: Theme.bg-canvas;
                    VerticalLayout {
                        padding: Theme.s-3;
                        TextEdit {
                            text <=> AppState.cl-current-body;
                            edited => { AppState.cl-dirty = true; }
                            font-size: Theme.font-code;
                            font-family: Theme.font-mono;
                        }
                    }
                }
            }
        }
    }
}

// ---- Settings --------------------------------------------------------------

component SettingsField inherits VerticalLayout {
    in property <string> label;
    in property <string> placeholder;
    in-out property <string> text;
    in property <bool> password: false;
    spacing: Theme.s-1;
    Text {
        text: root.label;
        color: Theme.on-surface-variant;
        font-family: Theme.font-mono;
        font-size: Theme.font-code;
        font-weight: Theme.w-bold;
    }
    CustomInput {
        text <=> root.text;
        placeholder: root.placeholder;
        password: root.password;
    }
}

component AgentConfigCard inherits Rectangle {
    in-out property <string> agent-name;
    in-out property <string> provider;
    in-out property <string> model-name;
    in-out property <string> base-url;
    in-out property <string> auth-token;
    in property <bool> active: false;
    callback save();
    callback restart();

    horizontal-stretch: 1;
    background: #0f172a;
    border-radius: Theme.radius-xl;
    border-width: 1px;
    border-color: root.active ? Theme.primary : Theme.outline-variant.with-alpha(0.6);

    VerticalLayout {
        padding: Theme.s-4;
        spacing: Theme.s-4;

        // Header — agent icon, name, status chip.
        HorizontalLayout {
            spacing: Theme.s-2;
            alignment: stretch;
            Icon {
                glyph: root.agent-name == "emma" ? Icons.target
                    : root.agent-name == "brian" ? Icons.settings
                    : Icons.target;
                size: 18px;
                tint:
                    root.agent-name == "emma" ? Theme.secondary :
                    root.agent-name == "brian" ? Theme.primary :
                    root.agent-name == "rain" ? Theme.tertiary :
                    Theme.on-surface;
            }
            Text {
                text: root.agent-name == "emma" ? "Emma"
                    : root.agent-name == "brian" ? "Brian"
                    : root.agent-name == "rain" ? "Rain"
                    : root.agent-name;
                color: Theme.on-surface;
                font-family: Theme.font-display;
                font-size: Theme.font-head-md;
                font-weight: Theme.w-semi;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
            // Role chip — describes what the agent DOES in bot-hq's trio,
            // not whether it's "active". Each session spawns one Brian (exec)
            // + one Rain (monitor); Emma is the always-on solo helper.
            VerticalLayout {
                alignment: center;
                LabelChip {
                    label:
                        root.agent-name == "emma" ? "HELPER · SOLO" :
                        root.agent-name == "brian" ? "EXEC · HANDS" :
                        root.agent-name == "rain" ? "MONITOR · EYES" :
                        "";
                    tint:
                        root.agent-name == "emma" ? Theme.secondary :
                        root.agent-name == "brian" ? Theme.primary :
                        root.agent-name == "rain" ? Theme.tertiary :
                        Theme.on-surface-variant;
                }
            }
        }

        SettingsField {
            label: "Provider";
            placeholder: "OpenAI / Anthropic / Local";
            text <=> root.provider;
        }
        SettingsField {
            label: "Model Name";
            placeholder: "claude-sonnet-4-6";
            text <=> root.model-name;
        }
        SettingsField {
            label: "Base URL";
            placeholder: "https://api.anthropic.com/v1";
            text <=> root.base-url;
        }
        SettingsField {
            label: "Auth Token";
            placeholder: "Optional for local";
            text <=> root.auth-token;
            password: true;
        }

        HorizontalLayout {
            alignment: end;
            spacing: Theme.s-2;
            if root.agent-name == "emma":
                GhostButton {
                    label: "Restart Emma";
                    icon: Icons.refresh;
                    clicked => { root.restart(); }
                }
            PrimaryButton {
                label: "Save Configuration";
                icon: Icons.check;
                clicked => { root.save(); }
            }
        }
    }
}

component SettingsPane inherits Rectangle {
    background: Theme.bg-canvas;
    ScrollView {
        VerticalLayout {
            padding-left: Theme.s-6;
            padding-right: Theme.s-6;
            padding-top: Theme.s-6;
            padding-bottom: Theme.s-6;
            spacing: Theme.s-6;

            VerticalLayout {
                spacing: Theme.s-1;
                Text {
                    text: "Agent Configuration";
                    color: Theme.on-surface;
                    font-family: Theme.font-display;
                    font-size: Theme.font-head-lg;
                    font-weight: Theme.w-bold;
                    letter-spacing: Theme.ls-headline;
                }
                Text {
                    text: "Manage connection parameters for individual orchestration agents.";
                    color: Theme.on-surface-variant;
                    font-family: Theme.font-mono;
                    font-size: Theme.font-code;
                }
            }

            HorizontalLayout {
                spacing: Theme.s-4;
                alignment: stretch;
                for cfg in AppState.agent-configs:
                    AgentConfigCard {
                        init => {
                            self.agent-name = cfg.agent-name;
                            self.provider = cfg.provider;
                            self.model-name = cfg.model-name;
                            self.base-url = cfg.base-url;
                            self.auth-token = cfg.auth-token;
                        }
                        save => {
                            AppState.save-agent-config({
                                agent-name: self.agent-name,
                                provider: self.provider,
                                model-name: self.model-name,
                                base-url: self.base-url,
                                auth-token: self.auth-token,
                            });
                        }
                        restart => {
                            AppState.emma-restart-confirm-visible = true;
                        }
                    }
            }

            // External MCP — let another agent drive bot-hq. Section appears
            // even when external_mcp_url is empty (= server failed to bind);
            // we just show a status row instead of the URL + token.
            VerticalLayout {
                spacing: Theme.s-1;
                Text {
                    text: "External MCP";
                    color: Theme.on-surface;
                    font-family: Theme.font-display;
                    font-size: Theme.font-head-lg;
                    font-weight: Theme.w-bold;
                    letter-spacing: Theme.ls-headline;
                }
                Text {
                    text: "Bearer-token-authed MCP server for driving bot-hq from another agent (Claude Code, custom tooling, tests). Localhost only.";
                    color: Theme.on-surface-variant;
                    font-family: Theme.font-mono;
                    font-size: Theme.font-code;
                    wrap: word-wrap;
                }
            }

            Rectangle {
                background: #0f172a;
                border-radius: Theme.radius-xl;
                border-width: 1px;
                border-color: Theme.outline-variant.with-alpha(0.6);
                VerticalLayout {
                    padding: Theme.s-4;
                    spacing: Theme.s-3;

                    if AppState.external-mcp-url == "":
                        Text {
                            text: "External MCP unavailable — port busy or BOT_HQ_EXTERNAL_MCP_DISABLED=1 was set.";
                            color: Theme.on-surface-variant;
                            font-family: Theme.font-mono;
                            font-size: Theme.font-code;
                            wrap: word-wrap;
                        }

                    if AppState.external-mcp-url != "":
                        VerticalLayout {
                            spacing: Theme.s-3;

                            VerticalLayout {
                                spacing: 2px;
                                Text {
                                    text: "Endpoint URL";
                                    color: Theme.on-surface-variant;
                                    font-family: Theme.font-mono;
                                    font-size: Theme.font-label;
                                    letter-spacing: Theme.ls-label;
                                }
                                Rectangle {
                                    background: Theme.surface-lowest;
                                    border-radius: Theme.radius-lg;
                                    border-width: 1px;
                                    border-color: Theme.outline-variant;
                                    height: 36px;
                                    HorizontalLayout {
                                        padding-left: Theme.s-3;
                                        padding-right: Theme.s-3;
                                        TextInput {
                                            text: AppState.external-mcp-url;
                                            read-only: true;
                                            color: Theme.on-surface;
                                            font-family: Theme.font-mono;
                                            font-size: Theme.font-code;
                                            vertical-alignment: center;
                                            single-line: true;
                                            horizontal-stretch: 1;
                                            selection-background-color: Theme.primary.with-alpha(0.4);
                                            selection-foreground-color: Theme.on-surface;
                                        }
                                    }
                                }
                            }

                            VerticalLayout {
                                spacing: 2px;
                                HorizontalLayout {
                                    spacing: Theme.s-2;
                                    alignment: stretch;
                                    Text {
                                        text: "Bearer Token";
                                        color: Theme.on-surface-variant;
                                        font-family: Theme.font-mono;
                                        font-size: Theme.font-label;
                                        letter-spacing: Theme.ls-label;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                    }
                                    GhostButton {
                                        label: AppState.external-mcp-token-revealed ? "Hide" : "Reveal";
                                        btn-height: 22px;
                                        clicked => {
                                            AppState.external-mcp-token-revealed = !AppState.external-mcp-token-revealed;
                                        }
                                    }
                                }
                                Rectangle {
                                    background: Theme.surface-lowest;
                                    border-radius: Theme.radius-lg;
                                    border-width: 1px;
                                    border-color: Theme.outline-variant;
                                    height: 36px;
                                    HorizontalLayout {
                                        padding-left: Theme.s-3;
                                        padding-right: Theme.s-3;
                                        TextInput {
                                            text: AppState.external-mcp-token-revealed
                                                ? AppState.external-mcp-token
                                                : "••••••••-••••-••••-••••-••••••••••••";
                                            read-only: true;
                                            color: Theme.on-surface;
                                            font-family: Theme.font-mono;
                                            font-size: Theme.font-code;
                                            vertical-alignment: center;
                                            single-line: true;
                                            horizontal-stretch: 1;
                                            selection-background-color: Theme.primary.with-alpha(0.4);
                                            selection-foreground-color: Theme.on-surface;
                                        }
                                    }
                                }
                                Text {
                                    text: "Stored at ~/.bot-hq/mcp-token (mode 0600). Rotate by editing the file and restarting bot-hq.";
                                    color: Theme.on-surface-variant;
                                    font-family: Theme.font-mono;
                                    font-size: Theme.font-code;
                                    wrap: word-wrap;
                                }
                            }

                            Text {
                                text: "Override port via BOT_HQ_EXTERNAL_MCP_PORT. Disable entirely with BOT_HQ_EXTERNAL_MCP_DISABLED=1.";
                                color: Theme.on-surface-variant;
                                font-family: Theme.font-mono;
                                font-size: Theme.font-code;
                                wrap: word-wrap;
                            }
                        }
                }
            }
        }
    }
}

// ---- Emma overlay (terminal-style per design) ------------------------------

component EmmaMessage inherits VerticalLayout {
    in property <ChatMsg> msg;
    property <bool> is-user: msg.author == "user";
    property <color> author-color:
        is-user ? Theme.tertiary :
        msg.author == "emma" ? Theme.primary :
        msg.author == "brian" ? Theme.primary :
        msg.author == "rain" ? Theme.secondary :
        Theme.outline;
    property <string> author-label:
        is-user ? "USER" :
        msg.author == "emma" ? "EMMA" :
        msg.author == "brian" ? "BRIAN" :
        msg.author == "rain" ? "RAIN" :
        msg.author;

    spacing: Theme.s-2;

    HorizontalLayout {
        spacing: Theme.s-2;
        alignment: start;
        Rectangle {
            width: 24px;
            height: 24px;
            border-radius: Theme.radius-default;
            background: author-color;
            horizontal-stretch: 0;
            Icon {
                glyph: is-user ? Icons.target : Icons.dot;
                size: 12px;
                tint: Theme.on-primary;
            }
        }
        Text {
            text: author-label;
            color: author-color;
            font-family: Theme.font-mono;
            font-size: Theme.font-label;
            letter-spacing: Theme.ls-label;
            font-weight: Theme.w-bold;
            vertical-alignment: center;
        }
        Text {
            text: msg.created-at;
            color: Theme.on-surface-variant;
            font-family: Theme.font-mono;
            font-size: Theme.font-code;
            vertical-alignment: center;
        }
    }

    Rectangle {
        background: Theme.surface-high;
        border-radius: Theme.radius-lg;
        border-width: 1px;
        border-color: Theme.outline-variant.with-alpha(0.4);
        VerticalLayout {
            padding: Theme.s-3;
            spacing: Theme.s-2;
            TextInput {
                text: msg.content;
                read-only: true;
                wrap: word-wrap;
                single-line: false;
                color: Theme.on-surface;
                font-family: Theme.font-mono;
                font-size: Theme.font-code;
                selection-background-color: Theme.primary.with-alpha(0.4);
                selection-foreground-color: Theme.on-surface;
            }
        }
    }
}

component EmmaPane inherits Rectangle {
    background: Theme.surface-low;
    Rectangle {
        x: 0; y: 0;
        width: 1px; height: parent.height;
        background: Theme.outline-variant;
    }
    VerticalLayout {
        spacing: 0px;

        // Header.
        Rectangle {
            height: Theme.topbar-h;
            background: Theme.surface;
            Rectangle {
                x: 0; y: parent.height - 1px;
                width: parent.width; height: 1px;
                background: Theme.outline-variant;
            }
            HorizontalLayout {
                padding-left: Theme.s-4;
                padding-right: Theme.s-2;
                spacing: Theme.s-2;
                alignment: stretch;
                Icon { glyph: Icons.list; size: 18px; tint: Theme.primary; }
                Text {
                    text: "Emma Terminal";
                    color: Theme.on-surface;
                    font-family: Theme.font-display;
                    font-size: Theme.font-head-md;
                    font-weight: Theme.w-semi;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                IconButton {
                    glyph: Icons.x;
                    clicked => { AppState.toggle-emma(); }
                }
            }
        }

        // Messages.
        Rectangle {
            vertical-stretch: 1;
            background: Theme.surface-low;
            emma-sv := ScrollView {
                // See session-sv — same pattern, maintainer's clamp formula.
                property <int> scroll-tick: AppState.emma-scroll-tick;
                changed scroll-tick => {
                    emma-sv.viewport-y = min(0px, -emma-sv.viewport-height + emma-sv.visible-height);
                }
                VerticalLayout {
                    padding: Theme.s-4;
                    spacing: Theme.s-5;
                    alignment: start;
                    for msg in AppState.emma-msgs:
                        EmmaMessage { msg: msg; }
                    if AppState.emma-msgs.length == 0:
                        VerticalLayout {
                            padding: Theme.s-5;
                            alignment: center;
                            Text {
                                text: "Ask Emma anything.";
                                color: Theme.on-surface-variant;
                                font-family: Theme.font-mono;
                                font-size: Theme.font-code;
                                horizontal-alignment: center;
                            }
                        }
                }
            }
        }

        // Pending choice + awaiting banner — Emma's signaling events go here
        // (she's not a SessionView so active-pending-* doesn't apply to her).
        if AppState.emma-pending-choice:
            Rectangle {
                background: Theme.surface;
                Rectangle {
                    x: 0; y: 0;
                    width: parent.width; height: 1px;
                    background: Theme.outline-variant;
                }
                VerticalLayout {
                    padding: Theme.s-3;
                    spacing: Theme.s-2;
                    Text {
                        text: AppState.emma-pending-question;
                        color: Theme.on-surface;
                        font-family: Theme.font-mono;
                        font-size: Theme.font-code;
                        wrap: word-wrap;
                    }
                    for opt in AppState.emma-pending-options:
                        ChoiceButton {
                            label: opt;
                            clicked => {
                                AppState.choice-clicked(AppState.emma-pending-choice-id, opt);
                            }
                        }
                }
            }
        if AppState.emma-awaiting && !AppState.emma-pending-choice:
            Rectangle {
                background: Theme.surface;
                Rectangle {
                    x: 0; y: 0;
                    width: parent.width; height: 1px;
                    background: Theme.outline-variant;
                }
                VerticalLayout {
                    padding: Theme.s-3;
                    Text {
                        text: "Emma is waiting on you.";
                        color: Theme.on-surface-variant;
                        font-family: Theme.font-mono;
                        font-size: Theme.font-code;
                    }
                }
            }

        // Terminal-style command input (Emma IS terminal-y per design).
        // Same auto-grow + Flickable-scroll model as ChatInput, with the `$`
        // prefix Text and Send IconButton kept as HorizontalLayout siblings
        // alongside the Flickable (so they stay anchored top regardless of
        // how tall the input grows).
        Rectangle {
            background: Theme.surface;
            Rectangle {
                x: 0; y: 0;
                width: parent.width; height: 1px;
                background: Theme.outline-variant;
            }
            VerticalLayout {
                padding: Theme.s-3;
                Rectangle {
                    // Same 1-line floor / 4-line ceiling as ChatInput. See the
                    // ChatInput comment for why `height:` instead of min/max/
                    // preferred — Slint's layout doesn't honor preferred-height
                    // on clipping children, so we compute the size directly.
                    height: clamp(cmd.preferred-height + Theme.s-2 * 2, 36px, 84px);
                    clip: true;
                    border-radius: Theme.radius-lg;
                    border-width: 1px;
                    border-color: cmd.has-focus ? Theme.primary : Theme.outline-variant;
                    background: Theme.surface-lowest;
                    animate border-color { duration: 100ms; }
                    forward-focus: cmd;
                    HorizontalLayout {
                        padding-left: Theme.s-3;
                        padding-right: Theme.s-3;
                        padding-top: Theme.s-2;
                        padding-bottom: Theme.s-2;
                        spacing: Theme.s-2;
                        alignment: stretch;
                        Text {
                            text: "$";
                            color: Theme.primary;
                            font-family: Theme.font-mono;
                            font-size: Theme.font-code;
                            font-weight: Theme.w-bold;
                            vertical-alignment: top;
                        }
                        emma-scroll := Flickable {
                            horizontal-stretch: 1;
                            interactive: true;
                            viewport-width: self.width;
                            viewport-height: max(self.height, cmd.preferred-height);
                            cmd := TextInput {
                                width: parent.width;
                                color: Theme.on-surface;
                                font-family: Theme.font-mono;
                                font-size: Theme.font-code;
                                single-line: false;
                                wrap: word-wrap;
                                page-height: emma-scroll.height;
                                selection-background-color: Theme.primary.with-alpha(0.4);
                                selection-foreground-color: Theme.on-surface;
                                key-pressed(ev) => {
                                    if (ev.text == Key.Return && !ev.modifiers.shift) {
                                        if (self.text != "") {
                                            AppState.emma-send(self.text);
                                            self.text = "";
                                        }
                                        return accept;
                                    }
                                    return reject;
                                }
                                cursor-position-changed(cpos) => {
                                    if (cpos.y + emma-scroll.viewport-y < 0) {
                                        emma-scroll.viewport-y = -cpos.y;
                                    } else if (cpos.y + emma-scroll.viewport-y > emma-scroll.height - 20px) {
                                        emma-scroll.viewport-y = min(0px, emma-scroll.height - cpos.y - 20px);
                                    }
                                }
                            }
                        }
                        IconButton {
                            glyph: Icons.play;
                            size: 14px;
                            tint: Theme.primary;
                            clicked => {
                                if (cmd.text != "") {
                                    AppState.emma-send(cmd.text);
                                    cmd.text = "";
                                }
                            }
                        }
                    }
                    if cmd.text == "" && !cmd.has-focus:
                        Text {
                            x: 28px;
                            y: Theme.s-2;
                            width: parent.width - 28px - Theme.s-3;
                            text: "Type command...";
                            color: Theme.on-surface-variant.with-alpha(0.55);
                            font-family: Theme.font-mono;
                            font-size: Theme.font-code;
                            vertical-alignment: top;
                        }
                }
            }
        }
    }
}

// ---- AppWindow -------------------------------------------------------------

export component AppWindow inherits Window {
    title: "bot-hq";
    preferred-width: 1440px;
    preferred-height: 900px;
    min-width: 960px;
    min-height: 600px;
    background: Theme.bg-canvas;

    VerticalLayout {
        spacing: 0px;
        Topbar {}

        // Body — switches by current-tab + active-session-id. Emma overlay
        // slides in on the right when open.
        Rectangle {
            vertical-stretch: 1;
            HorizontalLayout {
                spacing: 0px;
                Rectangle {
                    horizontal-stretch: 1;
                    if AppState.current-tab == 0 && AppState.active-session-id == "" : DashboardPane {}
                    if AppState.current-tab == 0 && AppState.active-session-id != "" : SessionView {}
                    if AppState.current-tab == 1 : ContextLibraryPane {}
                    if AppState.current-tab == 2 : SettingsPane {}
                }
                if AppState.emma-open: Rectangle {
                    width: 480px;
                    EmmaPane {}
                }
            }
        }

        Footer {}
    }

    // Toast overlay — bottom-center, layered above the main content.
    if AppState.toast-visible:
        Rectangle {
            VerticalLayout {
                alignment: end;
                padding-bottom: 32px;
                HorizontalLayout {
                    alignment: center;
                    Rectangle {
                        background: Theme.surface-high;
                        border-color: Theme.outline-variant;
                        border-width: 1px;
                        border-radius: 10px;
                        min-height: 44px;
                        HorizontalLayout {
                            padding-left: Theme.s-5;
                            padding-right: Theme.s-5;
                            padding-top: Theme.s-3;
                            padding-bottom: Theme.s-3;
                            Text {
                                text: AppState.toast-text;
                                color: Theme.on-surface;
                                font-size: Theme.font-body-md;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }

    // Auto-dismiss toast after 3 seconds. Bound `running` keeps the timer
    // dormant unless a toast is visible.
    Timer {
        interval: 3s;
        running: AppState.toast-visible;
        triggered => {
            AppState.toast-visible = false;
        }
    }

    // Emma restart confirmation modal. Singleton — only one can be visible.
    // Center-anchored card over a dimmed backdrop. Backdrop swallows clicks so
    // the user can't interact with the app behind it.
    if AppState.emma-restart-confirm-visible:
        Rectangle {
            background: #00000088;
            // Swallow clicks on the backdrop (no dismiss-on-outside-click for
            // safety — kill-and-respawn is a real action, must be explicit).
            TouchArea { }
            VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    alignment: center;
                    Rectangle {
                        width: 440px;
                        background: Theme.surface-high;
                        border-radius: 12px;
                        border-width: 1px;
                        border-color: Theme.outline-variant;
                        VerticalLayout {
                            padding: Theme.s-5;
                            spacing: Theme.s-4;
                            Text {
                                text: "Restart Emma?";
                                color: Theme.on-surface;
                                font-family: Theme.font-display;
                                font-size: Theme.font-head-md;
                                font-weight: Theme.w-bold;
                            }
                            Text {
                                text: "She'll re-spawn with the saved model. Her in-process context resets — earlier turns stay visible in the chat, but Emma herself won't remember them.";
                                color: Theme.on-surface-variant;
                                font-family: Theme.font-mono;
                                font-size: Theme.font-code;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                alignment: end;
                                spacing: Theme.s-2;
                                GhostButton {
                                    label: "Cancel";
                                    clicked => {
                                        AppState.emma-restart-confirm-visible = false;
                                    }
                                }
                                PrimaryButton {
                                    label: "Restart";
                                    icon: Icons.refresh;
                                    clicked => {
                                        AppState.emma-restart-confirm-visible = false;
                                        AppState.restart-emma();
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

    // New session dialog: title + project picker.
    // Project selection auto-fills working_repo_path (from CL projects table).
    if AppState.new-session-dialog-open:
        Rectangle {
            background: #00000088;
            TouchArea { }
            VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    alignment: center;
                    Rectangle {
                        width: 560px;
                        background: Theme.surface-high;
                        border-radius: 12px;
                        border-width: 1px;
                        border-color: Theme.outline-variant;
                        VerticalLayout {
                            padding: Theme.s-5;
                            spacing: Theme.s-3;
                            Text {
                                text: "New session";
                                color: Theme.on-surface;
                                font-family: Theme.font-display;
                                font-size: Theme.font-head-md;
                                font-weight: Theme.w-bold;
                            }
                            Text {
                                text: "Pick a project — the working repo path is filled in from the CL. Title is what the session tile shows on the dashboard.";
                                color: Theme.on-surface-variant;
                                font-family: Theme.font-mono;
                                font-size: Theme.font-code;
                                wrap: word-wrap;
                            }
                            VerticalLayout {
                                spacing: Theme.s-1;
                                Text {
                                    text: "TITLE";
                                    color: Theme.on-surface-variant;
                                    font-family: Theme.font-mono;
                                    font-size: Theme.font-label;
                                    font-weight: Theme.w-bold;
                                    letter-spacing: Theme.ls-label;
                                }
                                CustomInput {
                                    text <=> AppState.new-session-title;
                                    placeholder: "what's this session for?";
                                }
                            }
                            VerticalLayout {
                                spacing: Theme.s-1;
                                Text {
                                    text: "PROJECT";
                                    color: Theme.on-surface-variant;
                                    font-family: Theme.font-mono;
                                    font-size: Theme.font-label;
                                    font-weight: Theme.w-bold;
                                    letter-spacing: Theme.ls-label;
                                }
                                if AppState.new-session-projects.length == 0:
                                    Text {
                                        text: "No projects with a working repo are registered yet. Open the CL tab, click a folder, and use 'Register as Project' to set one up.";
                                        color: Theme.on-surface-variant.with-alpha(0.7);
                                        font-family: Theme.font-mono;
                                        font-size: Theme.font-code;
                                        wrap: word-wrap;
                                    }
                                if AppState.new-session-projects.length > 0:
                                    Rectangle {
                                        height: 220px;
                                        border-radius: Theme.radius-lg;
                                        border-width: 1px;
                                        border-color: Theme.outline-variant;
                                        background: Theme.surface-lowest;
                                        clip: true;
                                        ScrollView {
                                            VerticalLayout {
                                                spacing: 0px;
                                                for proj in AppState.new-session-projects: Rectangle {
                                                    height: 44px;
                                                    background: AppState.new-session-project-name == proj.name ? Theme.primary.with-alpha(0.15) : transparent;
                                                    border-width: 0px;
                                                    TouchArea {
                                                        clicked => {
                                                            AppState.new-session-project-name = proj.name;
                                                            AppState.new-session-project-path = proj.path;
                                                        }
                                                    }
                                                    HorizontalLayout {
                                                        padding-left: Theme.s-3;
                                                        padding-right: Theme.s-3;
                                                        spacing: Theme.s-3;
                                                        alignment: start;
                                                        VerticalLayout {
                                                            alignment: center;
                                                            horizontal-stretch: 1;
                                                            Text {
                                                                text: proj.name;
                                                                color: Theme.on-surface;
                                                                font-family: Theme.font-mono;
                                                                font-size: Theme.font-body-md;
                                                                font-weight: AppState.new-session-project-name == proj.name ? Theme.w-bold : Theme.w-regular;
                                                            }
                                                            Text {
                                                                text: proj.path;
                                                                color: Theme.on-surface-variant.with-alpha(0.7);
                                                                font-family: Theme.font-mono;
                                                                font-size: Theme.font-code;
                                                                overflow: elide;
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                            }
                            HorizontalLayout {
                                alignment: end;
                                spacing: Theme.s-2;
                                GhostButton {
                                    label: "Cancel";
                                    clicked => {
                                        AppState.new-session-dialog-open = false;
                                    }
                                }
                                PrimaryButton {
                                    label: "Create";
                                    icon: Icons.plus;
                                    opacity: AppState.new-session-project-path == "" ? 0.5 : 1.0;
                                    clicked => {
                                        if (AppState.new-session-project-path != "") {
                                            AppState.create-session(
                                                AppState.new-session-title == "" ? AppState.new-session-project-name : AppState.new-session-title,
                                                AppState.new-session-project-path,
                                            );
                                            AppState.new-session-dialog-open = false;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

    // New CL file dialog.
    if AppState.cl-new-file-dialog-open:
        Rectangle {
            background: #00000088;
            TouchArea { }
            VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    alignment: center;
                    Rectangle {
                        width: 520px;
                        background: Theme.surface-high;
                        border-radius: 12px;
                        border-width: 1px;
                        border-color: Theme.outline-variant;
                        VerticalLayout {
                            padding: Theme.s-5;
                            spacing: Theme.s-3;
                            Text {
                                text: "New CL file";
                                color: Theme.on-surface;
                                font-family: Theme.font-display;
                                font-size: Theme.font-head-md;
                                font-weight: Theme.w-bold;
                            }
                            Text {
                                text: "Path is relative to the active project root. Description goes into the index — keep it short; agents read it first to decide if the file is relevant.";
                                color: Theme.on-surface-variant;
                                font-family: Theme.font-mono;
                                font-size: Theme.font-code;
                                wrap: word-wrap;
                            }
                            VerticalLayout {
                                spacing: Theme.s-1;
                                Text {
                                    text: "FILE PATH";
                                    color: Theme.on-surface-variant;
                                    font-family: Theme.font-mono;
                                    font-size: Theme.font-label;
                                    font-weight: Theme.w-bold;
                                    letter-spacing: Theme.ls-label;
                                }
                                CustomInput {
                                    text <=> AppState.cl-new-file-name;
                                    placeholder: "notes/foo.md  (must end in .md)";
                                }
                            }
                            VerticalLayout {
                                spacing: Theme.s-1;
                                Text {
                                    text: "DESCRIPTION";
                                    color: Theme.on-surface-variant;
                                    font-family: Theme.font-mono;
                                    font-size: Theme.font-label;
                                    font-weight: Theme.w-bold;
                                    letter-spacing: Theme.ls-label;
                                }
                                CustomInput {
                                    text <=> AppState.cl-new-file-description;
                                    placeholder: "what this file is about (one sentence)";
                                }
                            }
                            HorizontalLayout {
                                alignment: end;
                                spacing: Theme.s-2;
                                GhostButton {
                                    label: "Cancel";
                                    clicked => {
                                        AppState.cl-new-file-dialog-open = false;
                                    }
                                }
                                PrimaryButton {
                                    label: "Create";
                                    icon: Icons.plus;
                                    clicked => {
                                        AppState.cl-create-file(
                                            AppState.cl-new-file-name,
                                            AppState.cl-new-file-description,
                                        );
                                        AppState.cl-new-file-dialog-open = false;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

    // Register-as-project modal. Defaults populated by view-model when the
    // user clicks "Register as Project" in CLFolderView. cl_path is required
    // (it's where the project's CL lives — defaults to the folder's absolute
    // path); working_repo_path is optional.
    if AppState.cl-register-dialog-open:
        Rectangle {
            background: #00000088;
            TouchArea { }
            VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    alignment: center;
                    Rectangle {
                        width: 560px;
                        background: Theme.surface-high;
                        border-radius: 12px;
                        border-width: 1px;
                        border-color: Theme.outline-variant;
                        VerticalLayout {
                            padding: Theme.s-5;
                            spacing: Theme.s-3;
                            Text {
                                text: "Register as project";
                                color: Theme.on-surface;
                                font-family: Theme.font-display;
                                font-size: Theme.font-head-md;
                                font-weight: Theme.w-bold;
                            }
                            Text {
                                text: "Promote this folder to a first-class project. The CL path is where index + policy + folder descriptions live; the working repo is the git checkout sessions operate on.";
                                color: Theme.on-surface-variant;
                                font-family: Theme.font-mono;
                                font-size: Theme.font-code;
                                wrap: word-wrap;
                            }
                            VerticalLayout {
                                spacing: Theme.s-1;
                                Text {
                                    text: "NAME";
                                    color: Theme.on-surface-variant;
                                    font-family: Theme.font-mono;
                                    font-size: Theme.font-label;
                                    font-weight: Theme.w-bold;
                                    letter-spacing: Theme.ls-label;
                                }
                                CustomInput {
                                    text <=> AppState.cl-register-name;
                                    placeholder: "folder name (used as project id)";
                                }
                            }
                            VerticalLayout {
                                spacing: Theme.s-1;
                                Text {
                                    text: "CL PATH";
                                    color: Theme.on-surface-variant;
                                    font-family: Theme.font-mono;
                                    font-size: Theme.font-label;
                                    font-weight: Theme.w-bold;
                                    letter-spacing: Theme.ls-label;
                                }
                                CustomInput {
                                    text <=> AppState.cl-register-cl-path;
                                    placeholder: "absolute path where CL lives";
                                }
                            }
                            VerticalLayout {
                                spacing: Theme.s-1;
                                Text {
                                    text: "WORKING REPO (optional)";
                                    color: Theme.on-surface-variant;
                                    font-family: Theme.font-mono;
                                    font-size: Theme.font-label;
                                    font-weight: Theme.w-bold;
                                    letter-spacing: Theme.ls-label;
                                }
                                CustomInput {
                                    text <=> AppState.cl-register-working-repo;
                                    placeholder: "absolute path to the git checkout sessions operate on";
                                }
                            }
                            HorizontalLayout {
                                alignment: end;
                                spacing: Theme.s-2;
                                GhostButton {
                                    label: "Cancel";
                                    clicked => {
                                        AppState.cl-register-dialog-open = false;
                                    }
                                }
                                PrimaryButton {
                                    label: "Register";
                                    icon: Icons.lightbulb;
                                    opacity: AppState.cl-register-name == "" || AppState.cl-register-cl-path == ""
                                        ? 0.5 : 1.0;
                                    clicked => {
                                        if (AppState.cl-register-name != ""
                                            && AppState.cl-register-cl-path != "") {
                                            AppState.cl-register-project-submit();
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

    // Delete CL file confirmation.
    if AppState.cl-delete-confirm-path != "":
        Rectangle {
            background: #00000088;
            TouchArea { }
            VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    alignment: center;
                    Rectangle {
                        width: 440px;
                        background: Theme.surface-high;
                        border-radius: 12px;
                        border-width: 1px;
                        border-color: Theme.outline-variant;
                        VerticalLayout {
                            padding: Theme.s-5;
                            spacing: Theme.s-3;
                            Text {
                                text: "Delete this file?";
                                color: Theme.on-surface;
                                font-family: Theme.font-display;
                                font-size: Theme.font-head-md;
                                font-weight: Theme.w-bold;
                            }
                            Text {
                                text: AppState.cl-delete-confirm-path;
                                color: Theme.primary;
                                font-family: Theme.font-mono;
                                font-size: Theme.font-code;
                            }
                            Text {
                                text: "Removes the file from disk AND its index entry. Cannot be undone from the UI.";
                                color: Theme.on-surface-variant;
                                font-family: Theme.font-mono;
                                font-size: Theme.font-code;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                alignment: end;
                                spacing: Theme.s-2;
                                GhostButton {
                                    label: "Cancel";
                                    clicked => {
                                        AppState.cl-delete-confirm-path = "";
                                    }
                                }
                                PrimaryButton {
                                    label: "Delete";
                                    icon: Icons.x;
                                    clicked => {
                                        AppState.cl-delete-file(AppState.cl-delete-confirm-path);
                                        AppState.cl-delete-confirm-path = "";
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
}
